<% content_for :title, "Racer seasons" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Racer seasons</h1>
    <%= link_to "New racer season", new_racer_season_path, class: "btn btn-primary" %>
  </div>

  <div id="racer_seasons" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @racer_seasons.any? %>
      <% @racer_seasons.each do |racer_season| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render racer_season %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", racer_season, class: "btn btn-ghost btn-sm" %>
            <%= link_to "Edit", edit_racer_season_path(racer_season), class: "btn btn-ghost btn-sm" %>
            <%= button_to "Destroy", racer_season, method: :delete, class: "btn btn-error btn-sm", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No racer seasons found.</p>
    <% end %>
  </div>
</div>
