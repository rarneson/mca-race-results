<% content_for :title, "Compare - #{@race.name}" %>

<div class="max-w-[1100px] mx-auto px-4 md:px-6">
  <%= render "shared/hud/breadcrumb", trail: [
        { label: "races", path: races_path },
        { label: @race.slug, path: race_path(@race) },
        { label: "compare" }
      ] %>

  <%# Header %>
  <section class="pt-2 pb-5">
    <div class="hud-mono text-[11px] text-hud-accent tracking-[0.12em] mb-1">H2H</div>
    <h1 class="hud-mono text-[26px] font-bold text-hud-accent mt-1 mb-1.5 tracking-[0.02em] leading-tight">
      <%= @race.name.upcase %>
    </h1>
    <div class="hud-mono text-[12px] text-hud-ink-dim">
      ◷ <%= @race.race_date.strftime("%B %-d, %Y") %><% if @race.location.present? %> · ⌖ <%= @race.location %><% end %>
    </div>
  </section>

  <% if !@comparison_ready %>
    <div class="hud-panel p-8 text-center">
      <div class="hud-mono text-[13px] text-hud-ink-dim mb-3">
        $ select two racers from the standings to compare
      </div>
      <%= link_to "‹ BACK TO RACE", race_path(@race, category: @back_category), class: "hud-button" %>
    </div>
  <% else %>
    <%
      a_name = @racer_a.racer_season.racer.name
      b_name = @racer_b.racer_season.racer.name
      a_team = @racer_a.racer_season.team&.name
      b_team = @racer_b.racer_season.team&.name
      a_cat  = @racer_a.category&.name
      b_cat  = @racer_b.category&.name

      cumulative_for = ->(laps, lap_n) {
        return nil if lap_n < 1 || lap_n > laps.size
        lap = laps[lap_n - 1]
        lap.cumulative_time_ms || laps[0..lap_n - 1].map(&:lap_time_ms).compact.sum
      }

      gap_through_min = nil
      gap_leader_name = nil
      if @min_compare_laps > 0
        ca = cumulative_for.call(@laps_a, @min_compare_laps)
        cb = cumulative_for.call(@laps_b, @min_compare_laps)
        if ca && cb
          gap_through_min = (ca - cb).abs
          gap_leader_name = ca <= cb ? a_name : b_name
        end
      end

      all_lap_pairs = (1..@max_compare_laps).map do |n|
        la = @laps_a.find { |l| l.lap_number == n }
        lb = @laps_b.find { |l| l.lap_number == n }
        [n, la, lb]
      end

      fastest_lap_owner = nil
      fastest_lap_ms = nil
      fastest_lap_n = nil
      all_lap_pairs.each do |n, la, lb|
        [[la, a_name], [lb, b_name]].each do |lap, owner|
          next if lap.nil? || lap.lap_time_ms.nil?
          if fastest_lap_ms.nil? || lap.lap_time_ms < fastest_lap_ms
            fastest_lap_ms = lap.lap_time_ms
            fastest_lap_owner = owner
            fastest_lap_n = n
          end
        end
      end

      biggest_swing_n = nil
      biggest_swing_ms = nil
      all_lap_pairs.each do |n, la, lb|
        next unless la&.lap_time_ms && lb&.lap_time_ms
        delta = (la.lap_time_ms - lb.lap_time_ms).abs
        if biggest_swing_ms.nil? || delta > biggest_swing_ms
          biggest_swing_ms = delta
          biggest_swing_n = n
        end
      end
    %>

    <%# Hero strip: racer A | RESULT | racer B (stacks on mobile) %>
    <div class="grid gap-3 mb-3 grid-cols-1 md:grid-cols-3">
      <%# Racer A card %>
      <div class="hud-panel p-4">
        <div class="hud-label">◉ RACER_A</div>
        <%= link_to @racer_a.racer_season.racer,
              class: "hud-mono text-[18px] mt-2 text-hud-accent block no-underline hover:underline" do %>
          <%= a_name %>
        <% end %>
        <div class="hud-mono text-[11px] text-hud-ink-dim mt-1">
          <% sub_a = [] %>
          <% sub_a << "##{@racer_a.plate_number_snapshot}" if @racer_a.plate_number_snapshot.present? %>
          <% sub_a << a_team if a_team %>
          <%= sub_a.join(" · ") %>
        </div>
        <div class="hud-mono text-[10px] text-hud-ink-dim mt-2 tracking-[0.08em]">
          <% if a_cat %><span class="text-hud-cyan"><%= a_cat.upcase %></span> · <% end %>
          <% if @racer_a.finished? %>
            P<%= @racer_a.place ? sprintf('%02d', @racer_a.place) : '—' %>
          <% else %>
            <span class="text-hud-red"><%= @racer_a.status&.upcase || 'DNF' %></span>
          <% end %>
        </div>
        <div class="mt-3 pt-3 border-t border-hud-border">
          <div class="hud-microlabel">FINISH</div>
          <div class="hud-mono text-[16px] mt-1 <%= @racer_a.finished? ? 'text-hud-ink' : 'text-hud-red' %>">
            <% if @racer_a.finished? && @racer_a.total_time_ms %>
              <%= time_from_ms(@racer_a.total_time_ms) %>
            <% else %>
              —
            <% end %>
          </div>
          <div class="hud-mono text-[10px] text-hud-ink-dim mt-1">
            <%= @laps_a.size %> LAP<%= 's' if @laps_a.size != 1 %>
          </div>
        </div>
      </div>

      <%# RESULT card %>
      <div class="hud-panel p-4 text-center" style="border-color: var(--color-hud-accent);">
        <div class="hud-label">≣ RESULT</div>
        <% if @laps_a.size == @laps_b.size && @racer_a.finished? && @racer_b.finished? && @racer_a.total_time_ms && @racer_b.total_time_ms %>
          <% overall_gap = (@racer_a.total_time_ms - @racer_b.total_time_ms).abs %>
          <% leader = @racer_a.total_time_ms <= @racer_b.total_time_ms ? a_name : b_name %>
          <div class="hud-mono text-[10px] text-hud-ink-dim mt-3 tracking-[0.08em]">OVERALL GAP</div>
          <div class="hud-mono text-[22px] mt-1 <%= overall_gap.zero? ? 'text-hud-amber' : 'text-hud-accent' %>">
            <% if overall_gap.zero? %>
              TIE
            <% else %>
              +<%= time_from_ms(overall_gap) %>
            <% end %>
          </div>
          <% unless overall_gap.zero? %>
            <div class="hud-mono text-[11px] text-hud-ink-dim mt-1">→ <%= leader.upcase %></div>
          <% end %>
        <% elsif gap_through_min %>
          <div class="hud-mono text-[10px] text-hud-ink-dim mt-3 tracking-[0.08em]">
            GAP THROUGH L<%= sprintf('%02d', @min_compare_laps) %>
          </div>
          <div class="hud-mono text-[22px] mt-1 <%= gap_through_min.zero? ? 'text-hud-amber' : 'text-hud-accent' %>">
            <% if gap_through_min.zero? %>
              TIE
            <% else %>
              +<%= time_from_ms(gap_through_min) %>
            <% end %>
          </div>
          <% unless gap_through_min.zero? %>
            <div class="hud-mono text-[11px] text-hud-ink-dim mt-1">→ <%= gap_leader_name.upcase %></div>
          <% end %>
          <div class="hud-mono text-[9px] text-hud-ink-dim mt-2 tracking-[0.08em]">
            RAW: <%= @racer_a.total_time_ms ? time_from_ms(@racer_a.total_time_ms) : '—' %>
            · <%= @racer_b.total_time_ms ? time_from_ms(@racer_b.total_time_ms) : '—' %>
          </div>
        <% else %>
          <div class="hud-mono text-[16px] mt-4 text-hud-ink-dim">—</div>
          <div class="hud-mono text-[10px] text-hud-ink-dim mt-2">no comparable laps</div>
        <% end %>
      </div>

      <%# Racer B card %>
      <div class="hud-panel p-4">
        <div class="hud-label">◉ RACER_B</div>
        <%= link_to @racer_b.racer_season.racer,
              class: "hud-mono text-[18px] mt-2 text-hud-accent block no-underline hover:underline" do %>
          <%= b_name %>
        <% end %>
        <div class="hud-mono text-[11px] text-hud-ink-dim mt-1">
          <% sub_b = [] %>
          <% sub_b << "##{@racer_b.plate_number_snapshot}" if @racer_b.plate_number_snapshot.present? %>
          <% sub_b << b_team if b_team %>
          <%= sub_b.join(" · ") %>
        </div>
        <div class="hud-mono text-[10px] text-hud-ink-dim mt-2 tracking-[0.08em]">
          <% if b_cat %><span class="text-hud-cyan"><%= b_cat.upcase %></span> · <% end %>
          <% if @racer_b.finished? %>
            P<%= @racer_b.place ? sprintf('%02d', @racer_b.place) : '—' %>
          <% else %>
            <span class="text-hud-red"><%= @racer_b.status&.upcase || 'DNF' %></span>
          <% end %>
        </div>
        <div class="mt-3 pt-3 border-t border-hud-border">
          <div class="hud-microlabel">FINISH</div>
          <div class="hud-mono text-[16px] mt-1 <%= @racer_b.finished? ? 'text-hud-ink' : 'text-hud-red' %>">
            <% if @racer_b.finished? && @racer_b.total_time_ms %>
              <%= time_from_ms(@racer_b.total_time_ms) %>
            <% else %>
              —
            <% end %>
          </div>
          <div class="hud-mono text-[10px] text-hud-ink-dim mt-1">
            <%= @laps_b.size %> LAP<%= 's' if @laps_b.size != 1 %>
          </div>
        </div>
      </div>
    </div>

    <% if @cross_category %>
      <div class="hud-panel p-3 mb-3" style="border-color: var(--color-hud-amber);">
        <div class="hud-mono text-[11px] text-hud-amber tracking-[0.08em]">
          ⚠ DIFFERENT_CATEGORIES — <%= a_cat.upcase %> vs <%= b_cat.upcase %>
        </div>
        <div class="hud-mono text-[10px] text-hud-ink-dim mt-1">
          lap counts may differ; comparison is per-lap only
        </div>
      </div>
    <% end %>

    <%# Lap analysis chart %>
    <% if @max_compare_laps > 0 %>
      <div class="mb-3">
        <%= render "races/lap_analysis",
              racers: [ @racer_a, @racer_b ],
              max_laps: @max_compare_laps,
              title: "LAP_ANALYSIS",
              subtitle: "#{@max_compare_laps} lap#{'s' if @max_compare_laps != 1}" %>
      </div>
    <% end %>

    <%# Lap-by-lap table %>
    <div class="hud-panel overflow-hidden mb-4">
      <div class="flex items-center px-3.5 py-2.5 border-b border-hud-border">
        <div class="hud-label">LAP-BY-LAP</div>
      </div>

      <% if @max_compare_laps.zero? %>
        <div class="hud-mono text-[12px] text-hud-ink-dim text-center py-12">
          $ no lap data recorded for either racer
        </div>
      <% else %>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse min-w-[560px] md:min-w-[720px]">
            <thead class="bg-hud-row">
              <tr>
                <th class="hud-label text-left py-2.5 px-2 md:px-3 whitespace-nowrap border-r border-hud-border">LAP</th>
                <th class="hud-label text-right py-2.5 px-2 md:px-3 whitespace-nowrap border-r border-hud-border">
                  <span class="md:hidden"><%= a_name.split.first.upcase %></span>
                  <span class="hidden md:inline"><%= a_name.upcase %></span>
                </th>
                <th class="hud-label text-right py-2.5 px-2 md:px-3 whitespace-nowrap border-r border-hud-border">
                  <span class="md:hidden"><%= b_name.split.first.upcase %></span>
                  <span class="hidden md:inline"><%= b_name.upcase %></span>
                </th>
                <th class="hud-label text-right py-2.5 px-2 md:px-3 whitespace-nowrap border-r border-hud-border">LAP_GAP</th>
                <th class="hud-label text-right py-2.5 px-2 md:px-3 whitespace-nowrap border-r border-hud-border">TOTAL_GAP</th>
                <th class="hud-label text-left py-2.5 px-2 md:px-3 whitespace-nowrap">LEAD</th>
              </tr>
            </thead>
            <tbody>
              <% all_lap_pairs.each do |n, la, lb| %>
                <%
                  beyond_min = n > @min_compare_laps
                  a_ms = la&.lap_time_ms
                  b_ms = lb&.lap_time_ms

                  lap_delta = (a_ms && b_ms) ? a_ms - b_ms : nil
                  a_faster = lap_delta && lap_delta < 0
                  b_faster = lap_delta && lap_delta > 0

                  cum_a = cumulative_for.call(@laps_a, n)
                  cum_b = cumulative_for.call(@laps_b, n)
                  cum_delta = (cum_a && cum_b) ? cum_a - cum_b : nil
                  cum_leader = if cum_delta.nil?
                    nil
                  elsif cum_delta == 0
                    :tie
                  elsif cum_delta < 0
                    :a
                  else
                    :b
                  end
                %>
                <tr class="hud-row border-t border-hud-border <%= 'opacity-70' if beyond_min %>">
                  <td class="hud-mono px-2 md:px-3 py-2.5 text-hud-ink-dim whitespace-nowrap border-r border-hud-border">
                    L<%= sprintf('%02d', n) %>
                    <% if beyond_min %>
                      <span class="hud-mono text-[9px] text-hud-amber ml-1 tracking-[0.08em]">REF</span>
                    <% end %>
                  </td>
                  <td class="hud-mono px-2 md:px-3 py-2.5 text-right whitespace-nowrap border-r border-hud-border <%= a_faster ? 'text-hud-accent font-bold' : (b_faster ? 'text-hud-ink-dim' : 'text-hud-ink') %>">
                    <% if a_ms %>
                      <%= time_from_ms(a_ms) %>
                    <% elsif la.nil? && @racer_a.finished? == false && n > @laps_a.size %>
                      <span class="text-hud-red">DNF</span>
                    <% elsif la.nil? %>
                      <span class="text-hud-ink-dim">LAPPED</span>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="hud-mono px-2 md:px-3 py-2.5 text-right whitespace-nowrap border-r border-hud-border <%= b_faster ? 'text-hud-accent font-bold' : (a_faster ? 'text-hud-ink-dim' : 'text-hud-ink') %>">
                    <% if b_ms %>
                      <%= time_from_ms(b_ms) %>
                    <% elsif lb.nil? && @racer_b.finished? == false && n > @laps_b.size %>
                      <span class="text-hud-red">DNF</span>
                    <% elsif lb.nil? %>
                      <span class="text-hud-ink-dim">LAPPED</span>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="hud-mono px-2 md:px-3 py-2.5 text-right whitespace-nowrap border-r border-hud-border <%= lap_delta && lap_delta != 0 ? 'text-hud-amber' : 'text-hud-ink-dim' %>">
                    <% if lap_delta.nil? %>
                      —
                    <% elsif lap_delta == 0 %>
                      TIE
                    <% else %>
                      <%= format_signed_delta(lap_delta.abs) %>
                    <% end %>
                  </td>
                  <td class="hud-mono px-2 md:px-3 py-2.5 text-right whitespace-nowrap border-r border-hud-border <%= cum_delta && cum_delta != 0 ? 'text-hud-accent' : 'text-hud-ink-dim' %>">
                    <% if cum_delta.nil? %>
                      —
                    <% elsif cum_delta == 0 %>
                      TIE
                    <% else %>
                      <%= format_signed_delta(cum_delta.abs) %>
                    <% end %>
                  </td>
                  <td class="hud-mono px-2 md:px-3 py-2.5 whitespace-nowrap">
                    <% case cum_leader %>
                    <% when :a %>
                      <span class="text-hud-accent"><%= a_name.split.first.upcase %></span>
                    <% when :b %>
                      <span class="text-hud-accent"><%= b_name.split.first.upcase %></span>
                    <% when :tie %>
                      <span class="text-hud-amber">TIE</span>
                    <% else %>
                      <span class="text-hud-ink-dim">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>

    <%# Footnote %>
    <% if fastest_lap_ms || biggest_swing_ms %>
      <div class="hud-mono text-[11px] text-hud-ink-dim tracking-[0.04em] mb-4">
        <% notes = [] %>
        <% if fastest_lap_ms %>
          <% notes << "fastest lap: #{fastest_lap_owner} L#{fastest_lap_n} @ #{time_from_ms(fastest_lap_ms)}" %>
        <% end %>
        <% if biggest_swing_ms && biggest_swing_ms > 0 %>
          <% notes << "biggest swing: L#{biggest_swing_n} #{format_signed_delta(biggest_swing_ms)}" %>
        <% end %>
        $ <%= notes.join(" · ") %>
      </div>
    <% end %>
  <% end %>

  <div class="mt-4">
    <%= link_to "‹ #{@back_text}", @back_path, class: "hud-link hud-mono text-[12px]" %>
  </div>
</div>
