<% content_for :title, "Races" %>

<div class="max-w-[1100px] mx-auto px-6">
  <%= render "shared/hud/breadcrumb", trail: [{ label: "races" }] %>

  <%# Hero %>
  <section class="pt-5 pb-6">
    <div class="hud-label">RACES ::</div>
    <h1 class="hud-mono text-[36px] font-bold text-hud-accent mt-2.5 mb-1.5 tracking-[0.02em] leading-tight">
      ALL_RACES
    </h1>
    <p class="text-sm text-hud-ink-dim max-w-[640px] leading-relaxed m-0">
      Every MCA mountain bike race in the archive. Browse by season to see results.
    </p>
  </section>

  <%# Year sections %>
  <% @races_by_year.keys.sort.reverse.each do |year| %>
    <section class="mb-7">
      <div class="flex justify-between items-end mb-3 flex-wrap gap-3">
        <h2 class="hud-mono text-lg font-bold m-0 tracking-[0.04em] text-hud-ink">
<%= year %> SEASON
        </h2>
        <span class="hud-microlabel"><%= pluralize(@races_by_year[year].size, "race") %></span>
      </div>

      <div class="hud-panel overflow-hidden">
        <% @races_by_year[year].each_with_index do |race, i| %>
          <%= link_to race_path(race),
                class: "hud-row grid gap-3.5 items-center px-3 py-3 no-underline #{'border-t border-hud-border' if i > 0}",
                style: "grid-template-columns: 1fr auto;" do %>
            <div>
              <div class="font-semibold text-sm text-hud-ink"><%= race.name %></div>
              <div class="hud-mono text-[11px] text-hud-ink-dim mt-0.5">
                ◷ <%= race.race_date.strftime("%B %-d, %Y") %><% if race.location.present? %> · ⌖ <%= race.location %><% end %>
              </div>
            </div>
            <span class="hud-mono text-hud-accent text-sm">▸</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
