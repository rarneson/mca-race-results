<% content_for :title, "#{@race.name} - Race Results" %>

<div class="max-w-[1100px] mx-auto px-6"
     data-controller="race-show">
  <%= render "shared/hud/breadcrumb", trail: [
        { label: "races", path: races_path },
        { label: @race.slug }
      ] %>

  <%# Header %>
  <section class="pt-2 pb-5">
    <h1 class="hud-mono text-[30px] font-bold text-hud-accent mt-2 mb-1.5 tracking-[0.02em] leading-tight">
      <%= @race.name.upcase %>
    </h1>
    <div class="hud-mono text-[12px] text-hud-ink-dim">
      ◷ <%= @race.race_date.strftime("%B %-d, %Y") %><% if @race.location.present? %> · ⌖ <%= @race.location %><% end %>
    </div>
  </section>

  <%# Filters %>
  <div class="flex gap-2.5 items-end flex-wrap mb-4">
    <div class="min-w-[220px] flex-1">
      <div class="hud-label mb-1.5">CATEGORY</div>
      <select onchange="window.location.href=this.value"
              class="hud-select hud-mono w-full">
        <% @category_stats.each do |category_name, stats| %>
          <option value="<%= race_path(@race, category: category_name) %>" <%= 'selected' if @selected_category == category_name %>>
            <%= category_name %> (<%= stats[:count] %>)
          </option>
        <% end %>
      </select>
    </div>
    <div class="min-w-[220px] flex-1">
      <div class="hud-label mb-1.5">SEARCH</div>
      <input type="text"
             data-race-show-target="search"
             data-action="input->race-show#search"
             placeholder="name, team, or plate #"
             autocomplete="off"
             class="hud-input hud-mono w-full" />
    </div>
  </div>

  <%# Hero stat strip %>
  <div class="hud-panel p-4 grid gap-3 mb-5" style="grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));">
    <% if @overall_winner %>
      <% leader_sub_parts = [] %>
      <% leader_sub_parts << "##{@overall_winner.plate_number_snapshot}" if @overall_winner.plate_number_snapshot.present? %>
      <% leader_sub_parts << @overall_winner.racer_season.team.name if @overall_winner.racer_season.team %>
      <%= render "shared/hud/hero_stat",
            label: "◉ LEADER",
            value: @overall_winner.racer_season.racer.name,
            sub: leader_sub_parts.join(" · "),
            accent_color: "text-hud-accent" %>
    <% else %>
      <%= render "shared/hud/hero_stat", label: "◉ LEADER", value: "—" %>
    <% end %>

    <% if @fastest_lap %>
      <%= render "shared/hud/hero_stat",
            label: "⚡ FASTEST LAP",
            value: time_from_ms(@fastest_lap[:lap].lap_time_ms),
            sub: "#{@fastest_lap[:result].racer_season.racer.name} · L#{@fastest_lap[:lap].lap_number}",
            accent_color: "text-hud-amber" %>
    <% else %>
      <%= render "shared/hud/hero_stat", label: "⚡ FASTEST LAP", value: "—" %>
    <% end %>

    <%= render "shared/hud/hero_stat",
          label: "▣ FINISHERS",
          value: "#{@finished_count}/#{@participants_count}",
          sub: "#{@dnf_dns_count} did not finish" %>

    <%= render "shared/hud/hero_stat",
          label: "◷ AVG TIME",
          value: (@average_time && @average_time > 0) ? time_from_ms(@average_time) : "—",
          sub: "across finishers" %>
  </div>

  <%# Tabs %>
  <div data-controller="tabs">
    <div class="flex gap-1.5 mb-3 flex-wrap">
      <button type="button" data-tabs-target="tab" data-action="click->tabs#switch" class="hud-tab">
        ▶ RESULTS
      </button>
      <button type="button" data-tabs-target="tab" data-action="click->tabs#switch" class="hud-tab">
        ≣ LAP_ANALYSIS
      </button>
    </div>

    <%# RESULTS tab %>
    <div data-tabs-target="content">
      <div class="hud-panel overflow-hidden">
        <div class="flex items-center px-3.5 py-2.5 border-b border-hud-border flex-wrap gap-3">
          <div class="hud-mono text-[12px] uppercase tracking-[0.1em] text-hud-accent font-bold">
            <%= @selected_category %>
          </div>
          <div class="hud-label">
            STANDINGS<span data-race-show-target="filteredFlag" class="hidden"> [<span data-race-show-target="visibleCount"></span> matching]</span>
          </div>
        </div>

        <div class="overflow-x-auto" data-race-show-target="tableWrap">
          <table class="w-full border-collapse" style="min-width: 740px;">
            <thead class="sticky top-0 bg-hud-row z-[2]">
              <tr>
                <th class="py-2.5 pl-5 pr-0 w-[24px]" aria-hidden="true"></th>
                <th class="hud-label text-right py-2.5 px-3 cursor-pointer select-none whitespace-nowrap"
                    data-action="click->race-show#sort" data-key="pos">
                  POS <span data-race-show-target="sortIndicator" data-key="pos" class="ml-1 text-hud-accent">▲</span>
                </th>
                <th class="hud-label text-left py-2.5 px-3 cursor-pointer select-none whitespace-nowrap"
                    data-action="click->race-show#sort" data-key="plate">
                  # <span data-race-show-target="sortIndicator" data-key="plate" class="ml-1 text-hud-border">◇</span>
                </th>
                <th class="hud-label text-left py-2.5 px-3 cursor-pointer select-none whitespace-nowrap"
                    data-action="click->race-show#sort" data-key="name">
                  RACER <span data-race-show-target="sortIndicator" data-key="name" class="ml-1 text-hud-border">◇</span>
                </th>
                <th class="hud-label text-left py-2.5 px-3 cursor-pointer select-none whitespace-nowrap"
                    data-action="click->race-show#sort" data-key="team">
                  TEAM <span data-race-show-target="sortIndicator" data-key="team" class="ml-1 text-hud-border">◇</span>
                </th>
                <th class="hud-label text-right py-2.5 px-3 cursor-pointer select-none whitespace-nowrap"
                    data-action="click->race-show#sort" data-key="time">
                  TIME <span data-race-show-target="sortIndicator" data-key="time" class="ml-1 text-hud-border">◇</span>
                </th>
                <th class="hud-label text-right py-2.5 px-3 whitespace-nowrap">GAP</th>
              </tr>
            </thead>
            <tbody data-race-show-target="tbody">
              <% leader = @race_results.first %>
              <% @race_results.each do |result| %>
                <% is_dnf = !result.finished? %>
                <% gap_ms = (!is_dnf && result.total_time_ms && leader && leader.total_time_ms) ? result.total_time_ms - leader.total_time_ms : nil %>
                <% search_blob = [result.racer_season.racer.name, result.racer_season.team&.name, result.plate_number_snapshot].compact.join(" ").downcase %>
                <tr class="hud-row group border-t border-hud-border <%= 'opacity-70' if is_dnf %>"
                    data-race-show-target="row"
                    data-action="click->race-show#toggleExpand"
                    data-pos="<%= result.place || 9999 %>"
                    data-plate="<%= result.plate_number_snapshot.to_i %>"
                    data-name="<%= result.racer_season.racer.name.downcase %>"
                    data-team="<%= (result.racer_season.team&.name || '').downcase %>"
                    data-time="<%= result.total_time_ms || 999_999_999 %>"
                    data-dnf="<%= is_dnf %>"
                    data-search="<%= search_blob %>">
                  <td class="hud-mono pl-5 pr-0 py-2.5 w-[24px] text-hud-ink-dim">
                    <% unless is_dnf %>
                      <span class="group-hover:text-hud-accent" aria-hidden="true">
                        <span class="group-[.expanded]:hidden">+</span>
                        <span class="hidden group-[.expanded]:inline">−</span>
                      </span>
                    <% end %>
                  </td>
                  <td class="hud-mono px-3 py-2.5 text-right w-[60px] <%= result.place == 1 ? 'text-hud-amber font-bold' : (result.place && result.place <= 3 ? 'text-hud-amber' : 'text-hud-ink-dim') %>">
                    <%= is_dnf ? '—' : (result.place ? sprintf('%02d', result.place) : '—') %>
                  </td>
                  <td class="hud-mono px-3 py-2.5 text-hud-ink-dim w-[60px]">
                    <%= result.plate_number_snapshot.present? ? "##{result.plate_number_snapshot}" : '—' %>
                  </td>
                  <td class="px-3 py-2.5">
                    <div class="flex items-center gap-2 flex-wrap">
                      <%= link_to result.racer_season.racer.name,
                            racer_path(result.racer_season.racer),
                            class: "font-semibold text-sm text-hud-ink hover:text-hud-accent no-underline",
                            onclick: "event.stopPropagation()" %>
                      <% if is_dnf %>
                        <span class="hud-mono text-[9px] uppercase tracking-[0.08em] px-1.5 py-0.5 border border-hud-red text-hud-red rounded-sm"><%= result.status.upcase %></span>
                      <% end %>
                      <% if result.penalty.present? %>
                        <span class="hud-mono text-[9px] uppercase tracking-[0.08em] px-1.5 py-0.5 border border-hud-red text-hud-red rounded-sm">PEN</span>
                      <% end %>
                    </div>
                    <% if result.penalty.present? %>
                      <div class="hud-mono text-[10px] text-hud-red mt-1">↳ <%= result.penalty %></div>
                    <% end %>
                    <% if result.comments.present? %>
                      <div class="hud-mono text-[10px] text-hud-ink-dim mt-1"><%= result.comments %></div>
                    <% end %>
                  </td>
                  <td class="px-3 py-2.5">
                    <% if result.racer_season.team %>
                      <%= link_to result.racer_season.team.name,
                            team_path(result.racer_season.team),
                            class: "text-[13px] text-hud-ink-dim hover:text-hud-accent no-underline",
                            onclick: "event.stopPropagation()" %>
                    <% else %>
                      <span class="text-[13px] text-hud-ink-dim italic">orphaned</span>
                    <% end %>
                  </td>
                  <td class="hud-mono px-3 py-2.5 text-right whitespace-nowrap <%= is_dnf ? 'text-hud-red' : 'text-hud-accent' %>">
                    <% if is_dnf %>
                      — <%= result.status.upcase %> —
                    <% else %>
                      <%= time_from_ms(result.total_time_ms) %>
                    <% end %>
                  </td>
                  <td class="hud-mono px-3 py-2.5 text-right text-[12px] whitespace-nowrap <%= result.place == 1 ? 'text-hud-amber' : 'text-hud-ink-dim' %>">
                    <% if is_dnf %>
                      —
                    <% elsif result.place == 1 %>
                      LEADER
                    <% elsif gap_ms %>
                      +<%= time_from_ms(gap_ms) %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                </tr>
                <%# Expanded laps row %>
                <% unless is_dnf %>
                  <tr class="hidden bg-hud-row" data-race-show-target="expanded">
                    <td colspan="7" class="px-4 py-3.5" style="border-top: 1px dashed var(--color-hud-border);">
                      <% if result.race_result_laps.any? %>
                        <% fastest_for_racer = result.race_result_laps.map(&:lap_time_ms).compact.min %>
                        <div class="grid gap-2.5" style="grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
                          <% result.race_result_laps.sort_by(&:lap_number).each do |lap| %>
                            <% is_fastest = lap.lap_time_ms.present? && lap.lap_time_ms == fastest_for_racer %>
                            <div class="hud-panel p-3" style="<%= 'border-color: var(--color-hud-amber);' if is_fastest %>">
                              <div class="hud-label">LAP_<%= lap.lap_number %></div>
                              <div class="hud-mono text-[18px] mt-1 <%= is_fastest ? 'text-hud-amber' : 'text-hud-ink' %>">
                                <%= lap.lap_time_ms ? time_from_ms(lap.lap_time_ms) : '—:——.—' %>
                              </div>
                              <% if is_fastest %>
                                <div class="hud-mono text-[9px] text-hud-amber mt-1 tracking-[0.08em]">↳ FASTEST</div>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                      <% else %>
                        <div class="hud-mono text-[12px] text-hud-ink-dim">$ no lap data recorded</div>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Empty state for filter %>
        <div data-race-show-target="emptyState" class="hidden hud-mono text-center py-12 px-4 text-hud-ink-dim">
          <div class="text-[13px] mb-3">$ no records match "<span data-race-show-target="emptyQuery"></span>"</div>
          <button type="button" data-action="click->race-show#clearSearch" class="hud-button">clear filter</button>
        </div>
      </div>

      <div class="hud-mono text-[11px] text-hud-ink-dim mt-3.5 tracking-[0.04em]">
        $ tap a row → expand laps · click a racer name → profile · click column header to sort
      </div>
    </div>

    <%# LAP_ANALYSIS tab %>
    <div data-tabs-target="content">
      <%= render "races/lap_analysis", race_results: @race_results, max_laps: @max_laps %>
    </div>
  </div>
</div>
