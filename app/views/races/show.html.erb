<% content_for(:title, "#{@race.name} - MTB Race Center") %>

<div class="max-w-7xl mx-auto bg-gray-50 min-h-screen">
  <!-- Header -->
  <div class="bg-gray-100 p-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="bg-emerald-600 text-white p-2 rounded-lg">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 8c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-8-5c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-8 5c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Race Results</h1>
          <p class="text-gray-600">Live race results and statistics</p>
        </div>
      </div>
      <div class="flex gap-2">
        <%= link_to races_path, class: "flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50" do %>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z"/>
          </svg>
          Home
        <% end %>
        <%= link_to races_path, class: "flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700" do %>
          Races
        <% end %>
      </div>
    </div>
  </div>

  <!-- Race Title -->
  <div class="p-6 bg-white border-b">
    <h2 class="text-2xl font-bold text-emerald-600 mb-2"><%= @race.name %></h2>
    <div class="flex items-center gap-6 text-gray-600">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
        </svg>
        <%= @race.race_date.strftime("%B %d, %Y") %>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <%= @race.location %>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="p-6">
    <!-- Filter by Category -->
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12H9.97L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3V3H19V3C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14.03,12H14Z"/>
        </svg>
        <span class="text-sm font-medium text-gray-700">Filter by Category</span>
      </div>
      <div class="relative inline-block w-64">
        <select onchange="window.location.href=this.value" class="block w-full px-4 py-2 pr-8 bg-white border border-gray-300 rounded-lg text-gray-700 hover:border-gray-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 focus:outline-none appearance-none">
          <% @category_stats.each do |category_name, stats| %>
            <option value="<%= race_path(@race, category: category_name) %>" <%= 'selected' if @selected_category == category_name %>>
              <%= category_name %> (<%= stats[:count] %>)
            </option>
          <% end %>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 10l5 5 5-5z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="mb-6">
      <div class="border-b border-gray-200">
        <nav class="-mb-px flex space-x-8">
          <div class="border-emerald-500 text-emerald-600 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16,6H8A2,2 0 0,0 6,8V16A2,2 0 0,0 8,18H16A2,2 0 0,0 18,16V8A2,2 0 0,0 16,6M16,16H8V8H16V16Z"/>
            </svg>
            Results
          </div>
          <div class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
            </svg>
            Lap Analysis
          </div>
        </nav>
      </div>
    </div>

    <!-- Race Results Table -->
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M19,19H5V5H19V19Z"/>
          </svg>
          <h3 class="text-lg font-semibold text-gray-900">Race Results</h3>
        </div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pos</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
              <% (1..@max_laps).each do |lap_num| %>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Lap <%= lap_num %></th>
              <% end %>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gap</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Comments</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @race_results.each_with_index do |result, index| %>
              <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <% if result.place == 1 %>
                      <div class="flex items-center justify-center w-8 h-8 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold">
                        1
                      </div>
                    <% elsif result.place == 2 %>
                      <div class="flex items-center justify-center w-8 h-8 bg-gray-100 text-gray-800 rounded-full text-sm font-bold">
                        2
                      </div>
                    <% elsif result.place == 3 %>
                      <div class="flex items-center justify-center w-8 h-8 bg-amber-100 text-amber-800 rounded-full text-sm font-bold">
                        3
                      </div>
                    <% else %>
                      <span class="text-lg font-semibold text-gray-900"><%= result.place || '-' %></span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= result.plate_number_snapshot %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div>
                    <div class="text-sm font-medium text-gray-900">
                      <%= result.racer_season.racer.first_name %> <%= result.racer_season.racer.last_name %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= result.racer_season.team&.name || 'Independent' %>
                </td>
                <% (1..@max_laps).each do |lap_num| %>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <% lap = result.race_result_laps.find { |l| l.lap_number == lap_num } %>
                    <% if lap && lap.lap_time_ms %>
                      <%= time_from_ms(lap.lap_time_ms) %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                <% end %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
                    </svg>
                    <span class="text-sm font-medium text-gray-900">
                      <%= time_from_ms(result.total_time_ms) %>
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if result.place && result.place > 1 && @overall_winner && result.total_time_ms && @overall_winner.total_time_ms %>
                    <% gap_ms = result.total_time_ms - @overall_winner.total_time_ms %>
                    +<%= time_from_ms(gap_ms) %>
                  <% else %>
                    <%= result.place == 1 ? 'Leader' : '-' %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if result.status && result.status != 'finished' %>
                    <% status_class = case result.status.upcase
                                       when 'DNF' then 'bg-red-100 text-red-800'
                                       when 'DNS' then 'bg-yellow-100 text-yellow-800'
                                       when 'DSQ' then 'bg-purple-100 text-purple-800'
                                       else 'bg-gray-100 text-gray-800'
                                       end %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= status_class %>">
                      <%= result.status.upcase %>
                    </span>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>