<% content_for(:title, "#{@race.name} - MTB Race Center") %>

<div class="container mx-auto px-4 py-6">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Race Results</h1>
    <p class="text-gray-600">Browse all race results by season</p>
  </div>

  <!-- Race Title -->
  <div class="p-6 bg-white border-b">
    <h2 class="text-2xl font-bold text-emerald-600 mb-2"><%= @race.name %></h2>
    <div class="flex items-center gap-6 text-gray-600 mb-2">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/>
        </svg>
        <%= @race.race_date.strftime("%B %d, %Y") %>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <%= @race.location %>
      </div>
    </div>
    <div class="text-gray-600">
      <%= @race.description %>
    </div>
  </div>

  <!-- Main Content -->
  <div class="p-6">
    <!-- Filter by Category -->
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12H9.97L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3V3H19V3C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14.03,12H14Z"/>
        </svg>
        <span class="text-sm font-medium text-gray-700">Filter by Category</span>
      </div>
      <div class="relative inline-block w-64">
        <select onchange="window.location.href=this.value" class="block w-full px-4 py-2 pr-8 bg-white border border-gray-300 rounded-lg text-gray-700 hover:border-gray-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 focus:outline-none appearance-none">
          <% @category_stats.each do |category_name, stats| %>
            <option value="<%= race_path(@race, category: category_name) %>" <%= 'selected' if @selected_category == category_name %>>
              <%= category_name %> (<%= stats[:count] %>)
            </option>
          <% end %>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 10l5 5 5-5z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="mb-6">
      <div class="border-b border-gray-200">
        <nav class="-mb-px flex space-x-8">
          <button id="results-tab" class="tab-button border-emerald-500 text-emerald-600 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16,6H8A2,2 0 0,0 6,8V16A2,2 0 0,0 8,18H16A2,2 0 0,0 18,16V8A2,2 0 0,0 16,6M16,16H8V8H16V16Z"/>
            </svg>
            Results
          </button>
          <button id="lap-analysis-tab" class="tab-button border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
            </svg>
            Lap Analysis
          </button>
        </nav>
      </div>
    </div>

    <!-- Tab Content -->
    <!-- Race Results Table -->
    <div id="results-content" class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-semibold text-gray-900">Race Results</h3>
        </div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pos</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
              <% (1..@max_laps).each do |lap_num| %>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Lap <%= lap_num %></th>
              <% end %>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gap</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Comments</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Penalty</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @race_results.each_with_index do |result, index| %>
              <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <span class="text-gray-900"><%= result.place || '-' %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                  <%= result.plate_number_snapshot %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div>
                    <div class="text-sm font-medium text-gray-900">
                      <%= result.racer_season.racer.first_name.humanize %> <%= result.racer_season.racer.last_name.humanize %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= result.racer_season.team&.name || 'Orphaned!' %>
                </td>
                <% (1..@max_laps).each do |lap_num| %>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <% lap = result.race_result_laps.find { |l| l.lap_number == lap_num } %>
                    <% if lap && lap.lap_time_ms %>
                      <%= time_from_ms(lap.lap_time_ms) %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                <% end %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <svg class="w-4 h-4 text-gray-400 mr-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
                    </svg>
                    <span class="text-sm font-medium text-gray-900">
                      <%= time_from_ms(result.total_time_ms) %>
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% category_leader = @race_results.first %>
                  <% if result.place && result.place > 1 && category_leader && result.total_time_ms && category_leader.total_time_ms %>
                    <% gap_ms = result.total_time_ms - category_leader.total_time_ms %>
                    +<%= time_from_ms(gap_ms) %>
                  <% else %>
                    <%= result.place == 1 ? 'Leader' : '-' %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <% if result.status && result.status != 'finished' %>
                    <% status_class = case result.status.upcase
                                       when 'DNF' then 'bg-red-100 text-red-800'
                                       when 'DNS' then 'bg-yellow-100 text-yellow-800'
                                       when 'DSQ' then 'bg-purple-100 text-purple-800'
                                       else 'bg-gray-100 text-gray-800'
                                       end %>
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= status_class %>">
                      <%= result.status.upcase %>
                    </span>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <span class="text-gray-900"><%= result.comments || '-' %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <span class="text-gray-900"><%= result.penalty || '-' %></span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Lap Analysis Content -->
    <div id="lap-analysis-content" class="hidden">
      <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"/>
              </svg>
              <h3 class="text-lg font-semibold text-gray-900">Lap Times Analysis</h3>
            </div>
            
            <!-- Racer Selector -->
            <div class="relative w-64">
              <select id="racer-selector" class="block w-full px-4 py-2 pr-8 bg-white border border-gray-300 rounded-lg text-gray-700 hover:border-gray-400 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 focus:outline-none appearance-none">
                <% @race_results.each do |result| %>
                  <option value="<%= result.id %>" data-racer-name="<%= result.racer_season.racer.first_name.humanize %> <%= result.racer_season.racer.last_name.humanize %>" data-team="<%= result.racer_season.team&.name || 'Orphaned!' %>" data-category="<%= result.category&.name || 'Unknown' %>" data-position="<%= result.place || '-' %>">
                    <%= result.plate_number_snapshot %> <%= result.racer_season.racer.first_name.humanize %> <%= result.racer_season.racer.last_name.humanize %>
                  </option>
                <% end %>
              </select>
              <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M7 10l5 5 5-5z"/>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Racer Info Header -->
        <div id="racer-info" class="px-6 py-4 bg-gray-50 border-b border-gray-200">
          <div class="flex items-center justify-between">
            <div>
              <h2 id="racer-name" class="text-2xl font-bold text-gray-900"></h2>
              <div class="flex items-center gap-6 text-gray-600 mt-1">
                <span id="racer-team"></span>
                <span id="racer-category"></span>
              </div>
            </div>
            <div class="text-right">
              <div class="text-3xl font-bold text-gray-900" id="total-time"></div>
              <div class="text-gray-600" id="position-info"></div>
            </div>
          </div>
        </div>

        <!-- Lap Times Grid -->
        <div id="lap-times-grid" class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Lap time cards will be dynamically populated -->
        </div>

        <!-- Statistics Summary -->
        <div class="px-6 py-4 bg-gray-50 border-t border-gray-200">
          <div class="grid grid-cols-3 gap-6">
            <div class="text-center">
              <div class="text-lg font-bold text-yellow-600" id="best-lap-time"></div>
              <div class="text-sm text-gray-600">Best Lap</div>
              <div class="text-xs text-gray-500" id="best-lap-number"></div>
            </div>
            <div class="text-center">
              <div class="text-lg font-bold text-gray-900" id="average-lap-time"></div>
              <div class="text-sm text-gray-600">Average Lap</div>
            </div>
            <div class="text-center">
              <div class="text-lg font-bold text-gray-900" id="consistency-range"></div>
              <div class="text-sm text-gray-600">Consistency</div>
              <div class="text-xs text-gray-500" id="consistency-detail"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- JavaScript for Tab Functionality and Lap Analysis -->
  <script>
    // Tab switching functionality
    document.addEventListener('DOMContentLoaded', function() {
      const resultsTab = document.getElementById('results-tab');
      const lapAnalysisTab = document.getElementById('lap-analysis-tab');
      const resultsContent = document.getElementById('results-content');
      const lapAnalysisContent = document.getElementById('lap-analysis-content');
      const racerSelector = document.getElementById('racer-selector');

      // Tab click handlers
      resultsTab.addEventListener('click', function() {
        showResultsTab();
      });

      lapAnalysisTab.addEventListener('click', function() {
        showLapAnalysisTab();
      });

      // Racer selector change handler
      racerSelector.addEventListener('change', function() {
        updateLapAnalysis();
      });

      function showResultsTab() {
        resultsTab.className = 'tab-button border-emerald-500 text-emerald-600 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2';
        lapAnalysisTab.className = 'tab-button border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2';
        resultsContent.classList.remove('hidden');
        lapAnalysisContent.classList.add('hidden');
      }

      function showLapAnalysisTab() {
        lapAnalysisTab.className = 'tab-button border-emerald-500 text-emerald-600 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2';
        resultsTab.className = 'tab-button border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2';
        resultsContent.classList.add('hidden');
        lapAnalysisContent.classList.remove('hidden');
        updateLapAnalysis();
      }

      function updateLapAnalysis() {
        const selectedOption = racerSelector.options[racerSelector.selectedIndex];
        const resultId = selectedOption.value;
        
        // Update racer info
        document.getElementById('racer-name').textContent = selectedOption.dataset.racerName;
        document.getElementById('racer-team').textContent = selectedOption.dataset.team;
        document.getElementById('racer-category').textContent = selectedOption.dataset.category + ' • ';
        document.getElementById('position-info').textContent = 'Position #' + selectedOption.dataset.position;

        // Fetch lap data for selected racer
        fetchLapData(resultId);
      }

      async function fetchLapData(resultId) {
        try {
          const response = await fetch(`/race_results/${resultId}/lap_data`);
          const data = await response.json();
          
          displayLapTimes(data.laps);
          updateStatistics(data.laps, data.total_time);
        } catch (error) {
          console.error('Error fetching lap data:', error);
        }
      }

      function displayLapTimes(laps) {
        const grid = document.getElementById('lap-times-grid');
        
        if (!laps || laps.length === 0) {
          grid.innerHTML = '<div class="text-center text-gray-500">No lap data available</div>';
          return;
        }

        let bestLapTime = Math.min(...laps.map(lap => lap.lap_time_ms));
        
        grid.innerHTML = laps.map((lap, index) => {
          const isBest = lap.lap_time_ms === bestLapTime;
          const splitInfo = index > 0 ? calculateSplit(lap, laps[index - 1]) : null;
          
          return `
            <div class="p-4 border rounded-lg ${isBest ? 'border-yellow-300 bg-yellow-50' : (splitInfo && !splitInfo.faster ? 'border-red-200 bg-red-50' : 'border-gray-200 bg-white')} relative">
              ${isBest ? '<div class="absolute top-2 right-2 bg-yellow-500 text-white px-2 py-1 rounded text-xs font-bold flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M9 11H7l1.5-5H10v5zm5.5 0H11v-5h3.5l-1.5 5z"/></svg>Best</div>' : ''}
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="text-sm font-medium text-gray-600">Lap ${lap.lap_number}</div>
                  <div class="text-2xl font-bold ${isBest ? 'text-yellow-700' : 'text-gray-900'}">${formatTime(lap.lap_time_ms)}</div>
                  ${splitInfo ? `<div class="text-sm ${splitInfo.faster ? 'text-green-600' : 'text-red-500'}">Split: ${splitInfo.text}</div>` : ''}
                  ${splitInfo ? `<div class="text-sm text-gray-500">vs Lap ${index}: ${splitInfo.comparison || ''}</div>` : ''}
                  ${index > 0 ? `<div class="text-sm text-gray-500">Cumulative: ${formatTime(lap.cumulative_time_ms)}</div>` : ''}
                </div>
                ${splitInfo && !splitInfo.faster ? '<svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M7,14L12,9L17,14H7Z"/></svg>' : ''}
              </div>
            </div>
          `;
        }).join('');
      }

      function calculateSplit(currentLap, previousLap) {
        const diff = currentLap.lap_time_ms - previousLap.lap_time_ms;
        const faster = diff < 0;
        const seconds = Math.abs(diff) / 1000;
        const minutes = Math.floor(seconds / 60);
        const remainingSeconds = Math.floor(seconds % 60);
        
        let text;
        if (minutes > 0) {
          text = `${faster ? '' : '+'}${minutes}:${remainingSeconds.toString().padStart(2, '0')}${faster ? ' faster' : ' slower'}`;
        } else {
          text = `${faster ? '' : '+'}${remainingSeconds}s${faster ? ' faster' : ' slower'}`;
        }
        
        const comparison = faster ? `${Math.abs(remainingSeconds)}s faster` : `${remainingSeconds}s slower`;
        
        return { faster, text, comparison };
      }

      function updateStatistics(laps, totalTime) {
        if (!laps || laps.length === 0) return;

        const lapTimes = laps.map(lap => lap.lap_time_ms);
        const bestTime = Math.min(...lapTimes);
        const bestLapIndex = lapTimes.indexOf(bestTime);
        const averageTime = lapTimes.reduce((sum, time) => sum + time, 0) / lapTimes.length;
        const maxTime = Math.max(...lapTimes);
        const range = maxTime - bestTime;

        document.getElementById('total-time').textContent = formatTime(totalTime);
        document.getElementById('best-lap-time').textContent = formatTime(bestTime);
        document.getElementById('best-lap-number').textContent = `Lap ${bestLapIndex + 1}`;
        document.getElementById('average-lap-time').textContent = formatTime(averageTime);
        const rangeSeconds = Math.floor(range / 1000);
        document.getElementById('consistency-range').textContent = `+${rangeSeconds}s`;
        document.getElementById('consistency-detail').textContent = 'Range';
      }

      function formatTime(milliseconds) {
        if (!milliseconds) return '00:00.00';
        
        const totalSeconds = milliseconds / 1000;
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = Math.floor(totalSeconds % 60);
        const ms = Math.floor((milliseconds % 1000) / 10);
        
        return `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}.${ms.toString().padStart(2, '0')}`;
      }

      // Initialize with first racer selected
      if (racerSelector.options.length > 0) {
        updateLapAnalysis();
      }
    });
  </script>
</div>