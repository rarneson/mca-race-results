<% content_for :title, "Teams" %>

<div class="container mx-auto px-4 py-6">
  <% if notice %>
    <div class="alert alert-success mb-4">
      <%= notice %>
    </div>
  <% end %>

  <!-- Page Header -->
  <div class="flex flex-col gap-4 mb-8">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Teams</h1>

    <div class="flex flex-row items-center gap-2 sm:gap-4">
      <!-- Search -->
      <div class="flex items-center gap-2" data-controller="team-search" data-team-search-url-value="<%= teams_path %>">
        <input
          id="team_search"
          type="text"
          placeholder="Search teams..."
          class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 w-40 sm:w-64"
          data-team-search-target="input"
          data-action="input->team-search#search keydown->team-search#handleKeydown"
          value="<%= @search_query %>"
        />
      </div>

      <!-- Year Filter -->
      <div class="flex items-center gap-2">
        <%= form_with url: teams_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
          <%= form.select :year,
              options_for_select(@available_years.map { |year| [year, year] }, @selected_year),
              {},
              {
                class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500",
                onchange: "this.form.submit();"
              } %>
          <%= form.hidden_field :search, value: @search_query if @search_query.present? %>
        <% end %>
      </div>
    </div>

    <p class="text-gray-600" id="teams_count">
      <%= render partial: "teams/teams_count", locals: { total_teams: @total_teams, total_racers: @total_racers, selected_year: @selected_year } %>
    </p>
  </div>

  <!-- Main Content -->
  <div id="teams_table">
    <%= render partial: "teams/teams_table", locals: { teams: @teams, selected_year: @selected_year, search_query: @search_query } %>
  </div>
</div>
