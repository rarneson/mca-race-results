<% content_for :title, "Teams" %>

<div class="max-w-[1100px] mx-auto px-6">
  <%= render "shared/hud/breadcrumb", trail: [{ label: "teams" }] %>

  <%# Hero %>
  <section class="pt-5 pb-6">
    <h1 class="hud-mono text-[36px] font-bold text-hud-accent mt-2.5 mb-1.5 tracking-[0.02em] leading-tight">
      ALL_TEAMS.<%= @selected_year %>
    </h1>
    <p class="text-sm text-hud-ink-dim max-w-[640px] leading-relaxed m-0">
      Cycling teams competing in the MCA mountain bike series. Filter by season or search by name.
    </p>

    <%# Search %>
    <div class="mt-5 relative max-w-[560px]" data-controller="team-search" data-team-search-url-value="<%= teams_path %>">
      <input
        id="team_search"
        type="text"
        placeholder="$ search teams…"
        autocomplete="off"
        class="hud-input hud-mono w-full px-3.5 py-3 text-sm pr-9"
        data-team-search-target="input"
        data-action="input->team-search#search keydown->team-search#handleKeydown"
        value="<%= @search_query %>"
      />
      <span class="hud-blink absolute right-3.5 top-1/2 -translate-y-1/2 text-hud-accent pointer-events-none">▍</span>
    </div>
  </section>

  <%# Stat strip (re-renders on search via turbo-stream) %>
  <div id="teams_count" class="mb-7">
    <%= render partial: "teams/teams_count", locals: { total_teams: @total_teams, total_racers: @total_racers, selected_year: @selected_year } %>
  </div>

  <%# Season header + year tabs %>
  <div class="flex justify-between items-end mb-3 flex-wrap gap-3">
    <h2 class="hud-mono text-lg font-bold m-0 tracking-[0.04em] text-hud-ink">
<%= @selected_year %> SEASON
    </h2>
    <%= render "shared/hud/year_tabs",
          years: @available_years,
          selected: @selected_year,
          path_builder: ->(y) { teams_path(year: y, search: @search_query.presence) } %>
  </div>

  <%# Teams list (re-renders on search via turbo-stream) %>
  <div id="teams_table">
    <%= render partial: "teams/teams_table", locals: { teams: @teams, selected_year: @selected_year, search_query: @search_query } %>
  </div>
</div>
