<% content_for :title, "Teams" %>

<div class="container mx-auto px-4 py-6">
  <% if notice %>
    <div class="alert alert-success mb-4">
      <%= notice %>
    </div>
  <% end %>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 mb-8">
    <div>
      <%= render "shared/page_header", title: "Teams",
        subtitle: tag.span(render(partial: "teams/teams_count", locals: { total_teams: @total_teams, total_racers: @total_racers, selected_year: @selected_year }), id: "teams_count") %>
    </div>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-4">
      <!-- Search -->
      <div class="flex items-center gap-2" data-controller="team-search" data-team-search-url-value="<%= teams_path %>">
        <label for="team_search" class="text-sm font-medium text-gray-700">Team:</label>
        <input
          id="team_search"
          type="text"
          placeholder="Search teams..."
          class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 w-full sm:w-64"
          data-team-search-target="input"
          data-action="input->team-search#search keydown->team-search#handleKeydown"
          value="<%= @search_query %>"
        />
      </div>

      <!-- Year Filter -->
      <div class="flex items-center gap-2">
        <%= form_with url: teams_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
          <%= form.label :year, "Year:", class: "text-sm font-medium text-gray-700" %>
          <%= form.select :year,
              options_for_select(@available_years.map { |year| [year, year] }, @selected_year),
              {},
              {
                class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500",
                onchange: "this.form.submit();"
              } %>
          <%= form.hidden_field :search, value: @search_query if @search_query.present? %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div id="teams_table">
    <%= render partial: "teams/teams_table", locals: { teams: @teams, selected_year: @selected_year, search_query: @search_query } %>
  </div>
</div>
