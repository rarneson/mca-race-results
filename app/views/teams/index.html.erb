<% if notice %>
  <div class="alert alert-success mb-4">
    <%= notice %>
  </div>
<% end %>

<% content_for :title, "Teams" %>

<div class="flex justify-between items-center mb-8">
  <h1 class="text-3xl font-bold">Teams</h1>
  <%= link_to "New Team", new_team_path, class: "btn btn-primary" %>
</div>

<div class="mb-6">
  <%= form_with url: teams_path, method: :get, local: true, class: "flex gap-2 items-center" do |form| %>
    <%= form.text_field :search, placeholder: "Search teams...", value: params[:search], class: "input input-bordered flex-1 max-w-md" %>
    <%= form.submit "Search", class: "btn btn-secondary" %>
    <% if params[:search].present? %>
      <%= link_to "Clear", teams_path, class: "btn btn-outline" %>
    <% end %>
  <% end %>
</div>

<div class="container mx-auto">
  <% if @teams.any? %>
    <div class="overflow-x-auto">
      <table class="table table-zebra">
        <thead>
          <tr>
            <th>Name</th>
            <th>Division</th>
            <th>Racers</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @teams.each do |team| %>
            <tr id="<%= dom_id team %>">
              <td class="font-medium"><%= team.name %></td>
              <td>
                <span class="badge badge-outline"><%= team.division&.humanize || 'No Division' %></span>
              </td>
              <td>
                <span class="font-semibold"><%= team.racers.count %></span>
              </td>
              <td class="text-right">
                <div class="flex gap-2 justify-end">
                  <%= link_to "View", team, class: "btn btn-sm btn-outline" %>
                  <%= link_to "Edit", edit_team_path(team), class: "btn btn-sm btn-secondary" %>
                  <%= button_to "Delete", team, method: :delete, 
                                class: "btn btn-sm btn-error", 
                                confirm: "Are you sure you want to delete #{team.name}?",
                                form: { style: "display: inline;" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="hero min-h-[400px]">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h3 class="text-2xl font-bold mb-4">No teams found</h3>
          <p class="mb-6">
            <% if params[:search].present? %>
              No teams match your search for "<%= params[:search] %>".
            <% else %>
              Get started by creating your first team.
            <% end %>
          </p>
          <%= link_to "Create New Team", new_team_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
