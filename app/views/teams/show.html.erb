<% if notice %>
  <div class="alert alert-success mb-6">
    <%= notice %>
  </div>
<% end %>

<div class="container mx-auto max-w-6xl p-6">
  <!-- Team Overview Header -->
  <div class="mb-8">
    <div class="flex items-center mb-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @team.name %></h1>
        <p class="text-gray-600">Complete roster and performance for <%= @selected_year %></p>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-gray-900"><%= @selected_year %> Team Statistics</h2>
      <div class="flex items-center space-x-2">
        <label for="year-filter-stats" class="text-sm font-medium text-gray-700">Year:</label>
        <%= form_with url: team_path(@team), method: :get, local: true, data: { turbo_frame: "_top" }, class: "inline-flex items-center space-x-2" do |form| %>
          <%= form.select :year, options_from_collection_for_select(@available_years, :itself, :itself, @selected_year), 
                        { prompt: "Select Year" }, 
                        { id: "year-filter-stats", class: "select select-bordered select-sm", onchange: "this.form.submit();" } %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <%= render 'shared/stat_card', 
        title: 'Total Racers',
        value: @team_stats[:total_racers],
        subtitle: 'Total Racers',
        icon: '' %>

    <%= render 'shared/stat_card', 
        title: 'Total Wins',
        value: @team_stats[:total_wins],
        subtitle: 'Total Wins',
        icon: '',
        color_class: 'bg-white',
        border_class: 'border-amber-200' %>

    <%= render 'shared/stat_card', 
        title: 'Total Podiums',
        value: @team_stats[:total_podiums],
        subtitle: 'Total Podiums',
        icon: '',
        color_class: 'bg-white',
        border_class: 'border-orange-200' %>

    <%= render 'shared/stat_card', 
        title: 'Best Finish',
        value: @team_stats[:best_finish] || "—",
        subtitle: 'Best Finish',
        icon: '' %>
  </div>

  <!-- Team Roster Section -->
  <div class="bg-white rounded-lg border border-gray-200" data-controller="tabs">
    <!-- Tab Headers -->
    <div class="border-b border-gray-200">
      <nav class="flex space-x-8 px-6">
        <button data-tabs-target="tab" data-action="click->tabs#switch" class="tab-button flex items-center py-4 border-b-2 border-gray-900 text-sm font-medium text-gray-900">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Team Roster
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#switch" class="tab-button flex items-center py-4 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          Race Results
        </button>
      </nav>
    </div>

    <!-- Team Roster Content -->
    <div data-tabs-target="content" class="p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Team Roster by Category</h2>
      
      <% if @racers_by_category.any? %>
        <% @racers_by_category.each do |category_name, racers| %>
          <div class="mb-8">
            <!-- Category Header -->
            <div class="flex items-center justify-between mb-4 p-4 bg-amber-50 rounded-lg border border-amber-200">
              <h3 class="text-lg font-semibold text-amber-800"><%= category_name %></h3>
              <span class="text-sm font-medium text-amber-700">
                <%= pluralize(racers.count, 'racer') %>
              </span>
            </div>
            
            <!-- Racers Table -->
            <div class="overflow-x-auto">
              <table class="min-w-full">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate #</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <% racers.each_with_index do |racer, index| %>
                    <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number || "##{index + 1}" %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                        <%= plate_number %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= racer.name %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= @team.name %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= link_to "View Profile", racer, class: "text-blue-600 hover:text-blue-900" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      <% elsif @team.racers.any? %>
        <!-- Show all racers if they exist but don't have categories -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">All Racers</h3>
            <span class="text-sm font-medium text-gray-700">
              <%= pluralize(@team.racers.count, 'racer') %>
            </span>
          </div>
          
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead>
                <tr class="border-b border-gray-200">
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate #</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <% @team.racers.each_with_index do |racer, index| %>
                  <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number || "V#{sprintf('%02d', index + 1)}" %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      <%= plate_number %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= racer.name %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= @team.name %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= link_to "View Profile", racer, class: "text-blue-600 hover:text-blue-900" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No racers found</h3>
          <p class="text-gray-500">This team doesn't have any racers assigned yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Race Results Content -->
    <div data-tabs-target="content" class="p-6">
      <div class="mb-6">
        <h2 class="text-xl font-bold text-gray-900">Race Results</h2>
      </div>
      
      <% if @team.racers.any? && @team.racers.map(&:race_results).flatten.any? %>
        <% all_results = @team.racers.map(&:race_results).flatten
                            .select { |r| r.race.race_date.year == @selected_year }
                            .sort_by { |r| [r.race.race_date, r.category&.name || '', r.place || 999] } %>
        <% if all_results.any? %>
          <% results_by_race = all_results.group_by(&:race) %>
          <% results_by_race.sort_by { |race, _| race.race_date }.each do |race, race_results| %>
            <div class="mb-8">
              <!-- Race Header -->
              <div class="flex items-center justify-between mb-4 p-4 bg-emerald-50 rounded-lg border border-emerald-200">
                <div>
                  <h3 class="text-lg font-semibold text-emerald-800"><%= race.name %></h3>
                  <p class="text-sm text-emerald-700"><%= race.race_date.strftime('%B %d, %Y') %> • <%= race.location %></p>
                </div>
                <span class="text-sm font-medium text-emerald-700">
                  <%= pluralize(race_results.count, 'result') %>
                </span>
              </div>
              
              <!-- Race Results by Category -->
              <% results_by_category = race_results.group_by { |r| r.category&.name || "No Category" } %>
              <% results_by_category.sort_by { |category_name, _| category_name }.each do |category_name, category_results| %>
                <div class="mb-6">
                  <!-- Category Header -->
                  <div class="flex items-center justify-between mb-3 p-3 bg-amber-50 rounded-lg border border-amber-200">
                    <h4 class="text-md font-semibold text-amber-800"><%= category_name %></h4>
                    <span class="text-sm font-medium text-amber-700">
                      <%= pluralize(category_results.count, 'result') %>
                    </span>
                  </div>
                  
                  <!-- Category Results Table -->
                  <div class="overflow-x-auto">
                    <table class="min-w-full">
                      <thead>
                        <tr class="border-b border-gray-200">
                          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Racer</th>
                          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Place</th>
                          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-200">
                        <% category_results.sort_by { |r| r.place || 999 }.each do |result| %>
                          <tr class="hover:bg-gray-50">
                            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                              <%= result.racer_season.racer.name %>
                            </td>
                            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                              <% if result.place %>
                                <span class="<%= place_css_class(result.place) %>">
                                  <%= result.place %>
                                </span>
                              <% else %>
                                —
                              <% end %>
                            </td>
                            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                              <% if result.total_time_ms %>
                                <%= Time.at(result.total_time_ms / 1000.0).utc.strftime('%M:%S.%L')[0..-3] %>
                              <% elsif result.total_time_raw.present? %>
                                <span class="text-orange-600"><%= result.total_time_raw %></span>
                              <% else %>
                                —
                              <% end %>
                            </td>
                            <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                              <%= link_to "View Result", result, class: "text-blue-600 hover:text-blue-900" %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-12">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <h3 class="text-lg font-medium text-gray-900 mb-2">No race results found for <%= @selected_year %></h3>
            <p class="text-gray-500">This team doesn't have any race results for the selected year.</p>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-12">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No race results found</h3>
          <p class="text-gray-500">This team doesn't have any race results yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
