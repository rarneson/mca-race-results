<% content_for :title, @team.name %>

<div class="max-w-[1100px] mx-auto px-6">
  <%= render "shared/hud/breadcrumb", trail: [
        { label: "teams", path: teams_path },
        { label: @team.name.parameterize.underscore }
      ] %>

  <%# Header %>
  <section class="pt-2 pb-5">
    <h1 class="hud-mono text-[30px] font-bold text-hud-accent mt-2 mb-1.5 tracking-[0.02em] leading-tight">
      <%= @team.name.upcase %>
    </h1>
    <div class="hud-mono text-[12px] text-hud-ink-dim">
      <%= pluralize(@team_stats[:total_racers], "rider") %> · <%= @selected_year %> season
    </div>
  </section>

  <%# Year tabs %>
  <div class="flex justify-between items-end mb-3 flex-wrap gap-3">
    <h2 class="hud-mono text-sm font-bold m-0 tracking-[0.04em] text-hud-ink">
<%= @selected_year %> SEASON
    </h2>
    <%= render "shared/hud/year_tabs",
          years: @available_years,
          selected: @selected_year,
          path_builder: ->(y) { team_path(@team, year: y) } %>
  </div>

  <%# Stat strip %>
  <div class="hud-panel p-4 grid gap-3 mb-7" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">
    <%= render "shared/hud/hero_stat",
          label: "▣ RACERS",
          value: @team_stats[:total_racers],
          sub: "on roster",
          accent_color: "text-hud-accent" %>
    <%= render "shared/hud/hero_stat",
          label: "★ WINS",
          value: @team_stats[:total_wins],
          sub: "1st-place finishes",
          accent_color: "text-hud-amber" %>
    <%= render "shared/hud/hero_stat",
          label: "◉ PODIUMS",
          value: @team_stats[:total_podiums],
          sub: "top-3 finishes",
          accent_color: "text-hud-amber" %>
    <%= render "shared/hud/hero_stat",
          label: "⌖ BEST",
          value: @team_stats[:best_finish] ? "P#{@team_stats[:best_finish]}" : "—",
          sub: "best finish",
          accent_color: "text-hud-accent" %>
  </div>

  <%# Tabs %>
  <div data-controller="tabs">
    <nav class="flex gap-1.5 mb-4 flex-wrap" role="tablist">
      <button type="button" data-tabs-target="tab" data-action="click->tabs#switch" class="hud-tab">
        TEAM_ROSTER
      </button>
      <button type="button" data-tabs-target="tab" data-action="click->tabs#switch" class="hud-tab">
        RACE_RESULTS
      </button>
    </nav>

    <%# Roster tab %>
    <div data-tabs-target="content">
      <% if @racers_by_category.any? %>
        <% @racers_by_category.each do |category_name, racers| %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-2.5">
              <h3 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
                <span class="text-hud-amber">◆</span> <%= category_name.upcase %>
              </h3>
              <span class="hud-microlabel"><%= pluralize(racers.count, "racer") %></span>
            </div>

            <div class="hud-panel overflow-hidden">
              <% racers.each_with_index do |racer, idx| %>
                <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number %>
                <%= link_to racer_path(racer),
                      class: "hud-row grid gap-3.5 items-center px-3 py-3 no-underline #{'border-t border-hud-border' if idx > 0}",
                      style: "grid-template-columns: 80px 1fr auto;" do %>
                  <span class="hud-mono text-[12px] text-hud-ink-dim">
                    <% if plate_number %>#<%= plate_number %><% else %>—<% end %>
                  </span>
                  <span class="font-normal text-sm text-hud-ink"><%= racer.name %></span>
                  <span class="hud-mono text-hud-accent text-sm">▸</span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% elsif @team.racers.any? %>
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2.5">
            <h3 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
              <span class="text-hud-amber">◆</span> ALL_RACERS
            </h3>
            <span class="hud-microlabel"><%= pluralize(@team.racers.count, "racer") %></span>
          </div>

          <div class="hud-panel overflow-hidden">
            <% @team.racers.each_with_index do |racer, idx| %>
              <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number %>
              <%= link_to racer_path(racer),
                    class: "hud-row grid gap-3.5 items-center px-3 py-3 no-underline #{'border-t border-hud-border' if idx > 0}",
                    style: "grid-template-columns: 80px 1fr auto;" do %>
                <span class="hud-mono text-[12px] text-hud-ink-dim">
                  <% if plate_number %>#<%= plate_number %><% else %>—<% end %>
                </span>
                <span class="font-normal text-sm text-hud-ink"><%= racer.name %></span>
                <span class="hud-mono text-hud-accent text-sm">▸</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="hud-panel p-8 text-center">
          <p class="hud-mono text-sm text-hud-ink-dim m-0">$ no racers on this roster</p>
        </div>
      <% end %>
    </div>

    <%# Race results tab %>
    <div data-tabs-target="content">
      <%
        all_results = @team.racers.flat_map(&:race_results)
                          .select { |r| r.race && r.race.race_date.year == @selected_year }
      %>

      <% if all_results.any? %>
        <% results_by_race = all_results.group_by(&:race) %>
        <% results_by_race.sort_by { |race, _| race.race_date }.each do |race, race_results| %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-2.5 flex-wrap gap-2">
              <div>
                <h3 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
<%= race.name.upcase %>
                </h3>
                <div class="hud-mono text-[11px] text-hud-ink-dim mt-0.5">
                  ◷ <%= race.race_date.strftime("%B %-d, %Y") %><% if race.location.present? %> · ⌖ <%= race.location %><% end %>
                </div>
              </div>
              <span class="hud-microlabel"><%= pluralize(race_results.count, "result") %></span>
            </div>

            <% results_by_category = race_results.group_by { |r| r.category&.name || "No Category" } %>
            <% results_by_category.sort_by { |category_name, _| category_name }.each do |category_name, category_results| %>
              <div class="hud-panel overflow-hidden mb-2.5">
                <div class="flex items-center justify-between px-3 py-2 border-b border-hud-border">
                  <span class="hud-microlabel"><%= category_name.upcase %></span>
                  <%= link_to "VIEW_RACE ▸", race_path(race, category: category_name), class: "hud-mono text-[10px] text-hud-accent no-underline hover:underline tracking-[0.06em]" %>
                </div>
                <% category_results.sort_by { |r| r.place || 999 }.each_with_index do |result, idx| %>
                  <div class="grid gap-3.5 items-center px-3 py-2.5 <%= 'border-t border-hud-border' if idx > 0 %>"
                       style="grid-template-columns: 60px 1fr auto;">
                    <span class="hud-mono text-sm <%= result.place == 1 ? 'text-hud-amber font-bold' : (result.place && result.place <= 3 ? 'text-hud-amber' : 'text-hud-ink-dim') %>">
                      <% if result.place %>P<%= result.place %><% else %>—<% end %>
                    </span>
                    <span class="text-sm text-hud-ink"><%= result.racer_season.racer.name %></span>
                    <span class="hud-mono text-[12px] <%= result.total_time_ms ? 'text-hud-accent' : 'text-hud-ink-dim' %>">
                      <% if result.total_time_ms %>
                        <%= Time.at(result.total_time_ms / 1000.0).utc.strftime("%M:%S.%L")[0..-3] %>
                      <% elsif result.total_time_raw.present? %>
                        <span class="text-hud-amber"><%= result.total_time_raw %></span>
                      <% else %>
                        —
                      <% end %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="hud-panel p-8 text-center">
          <p class="hud-mono text-sm text-hud-ink-dim m-0">$ no race results for <%= @selected_year %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
