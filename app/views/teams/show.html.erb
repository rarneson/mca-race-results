<% if notice %>
  <div class="alert alert-success mb-6">
    <%= notice %>
  </div>
<% end %>

<div class="container mx-auto max-w-6xl p-6">
  <!-- Back Button -->
  <div class="mb-6">
    <%= link_to teams_path, class: "flex items-center text-gray-600 hover:text-gray-800 transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to Results
    <% end %>
  </div>

  <!-- Team Overview Header -->
  <div class="mb-8">
    <div class="flex items-center mb-4">
      <div class="p-3 bg-green-100 rounded-lg mr-4">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @team.name %></h1>
        <p class="text-gray-600">Complete roster and performance across all categories</p>
      </div>
    </div>
  </div>

  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <!-- Total Racers -->
    <div class="bg-white rounded-lg p-6 border border-gray-200">
      <div class="flex items-center justify-between mb-2">
        <div class="p-2 bg-gray-100 rounded-lg">
          <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-gray-900 mb-1"><%= @team_stats[:total_racers] %></div>
      <div class="text-sm text-gray-600">Total Racers</div>
    </div>

    <!-- Total Wins -->
    <div class="bg-white rounded-lg p-6 border border-amber-200">
      <div class="flex items-center justify-between mb-2">
        <div class="p-2 bg-amber-100 rounded-lg">
          <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l2.09 6.26L20 9l-4.95 3.61L17.18 20 12 15.7 6.82 20l2.13-7.39L4 9l5.91-.74L12 2z"/>
          </svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-amber-600 mb-1"><%= @team_stats[:total_wins] %></div>
      <div class="text-sm text-gray-600">Total Wins</div>
    </div>

    <!-- Total Podiums -->
    <div class="bg-white rounded-lg p-6 border border-orange-200">
      <div class="flex items-center justify-between mb-2">
        <div class="p-2 bg-orange-100 rounded-lg">
          <svg class="w-5 h-5 text-orange-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 6V2l4 4-4 4V6c-3.31 0-6 2.69-6 6 0 1.66.67 3.16 1.76 4.24l1.42-1.42C8.45 14.09 8 13.1 8 12c0-2.21 1.79-4 4-4zm6.76 1.74l-1.42 1.42C17.55 9.91 18 10.9 18 12c0 2.21-1.79 4-4 4v-4l-4 4 4 4v-4c3.31 0 6-2.69 6-6 0-1.66-.67-3.16-1.76-4.24z"/>
          </svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-orange-600 mb-1"><%= @team_stats[:total_podiums] %></div>
      <div class="text-sm text-gray-600">Total Podiums</div>
    </div>

    <!-- Best Finish -->
    <div class="bg-white rounded-lg p-6 border border-gray-200">
      <div class="flex items-center justify-between mb-2">
        <div class="p-2 bg-gray-100 rounded-lg">
          <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l2.09 6.26L20 9l-4.95 3.61L17.18 20 12 15.7 6.82 20l2.13-7.39L4 9l5.91-.74L12 2z"/>
          </svg>
        </div>
      </div>
      <div class="text-3xl font-bold text-gray-900 mb-1">
        <%= @team_stats[:best_finish] || "—" %>
      </div>
      <div class="text-sm text-gray-600">Best Finish</div>
    </div>
  </div>

  <!-- Team Roster Section -->
  <div class="bg-white rounded-lg border border-gray-200">
    <!-- Tab Headers -->
    <div class="border-b border-gray-200">
      <nav class="flex space-x-8 px-6">
        <button id="roster-tab" class="tab-button flex items-center py-4 border-b-2 border-gray-900 text-sm font-medium text-gray-900">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Team Roster
        </button>
        <button id="results-tab" class="tab-button flex items-center py-4 border-b-2 border-transparent text-sm font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          Race Results
        </button>
      </nav>
    </div>

    <!-- Team Roster Content -->
    <div id="roster-content" class="p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Team Roster by Category (2024 Season)</h2>
      
      <% if @racers_by_category.any? %>
        <% @racers_by_category.each do |category_name, racers| %>
          <div class="mb-8">
            <!-- Category Header -->
            <div class="flex items-center justify-between mb-4 p-4 bg-amber-50 rounded-lg border border-amber-200">
              <h3 class="text-lg font-semibold text-amber-800"><%= category_name %></h3>
              <span class="text-sm font-medium text-amber-700">
                <%= pluralize(racers.count, 'racer') %>
              </span>
            </div>
            
            <!-- Racers Table -->
            <div class="overflow-x-auto">
              <table class="min-w-full">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate #</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <% racers.each_with_index do |racer, index| %>
                    <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number || "##{index + 1}" %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                        <%= plate_number %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                        <%= racer.name %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= @team.name %>
                      </td>
                      <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                        <%= link_to "View Profile", racer, class: "text-blue-600 hover:text-blue-900" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      <% elsif @team.racers.any? %>
        <!-- Show all racers if they exist but don't have categories -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">All Racers</h3>
            <span class="text-sm font-medium text-gray-700">
              <%= pluralize(@team.racers.count, 'racer') %>
            </span>
          </div>
          
          <div class="overflow-x-auto">
            <table class="min-w-full">
              <thead>
                <tr class="border-b border-gray-200">
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plate #</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Team</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <% @team.racers.each_with_index do |racer, index| %>
                  <% plate_number = racer.race_results.first&.plate_number_snapshot || racer.racer_seasons.first&.plate_number || "V#{sprintf('%02d', index + 1)}" %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      <%= plate_number %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                      <%= racer.name %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= @team.name %>
                    </td>
                    <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= link_to "View Profile", racer, class: "text-blue-600 hover:text-blue-900" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No racers found</h3>
          <p class="text-gray-500">This team doesn't have any racers assigned yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Race Results Content -->
    <div id="results-content" class="p-6 hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Race Results (2024 Season)</h2>
      
      <% if @team.racers.any? && @team.racers.map(&:race_results).flatten.any? %>
        <% all_results = @team.racers.map(&:race_results).flatten.sort_by { |r| [r.race.race_date, r.category&.name || '', r.place || 999] } %>
        <div class="overflow-x-auto">
          <table class="min-w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Race</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Racer</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Place</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% all_results.each do |result| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= result.race.name %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= result.category&.name || "—" %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= result.racer_season.racer.name %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900">
                    <% if result.place %>
                      <span class="<%= result.place <= 3 ? 'font-bold' : '' %> <%= result.place == 1 ? 'text-amber-600' : result.place <= 3 ? 'text-orange-600' : '' %>">
                        <%= result.place %>
                      </span>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                    <% if result.total_time_ms %>
                      <%= Time.at(result.total_time_ms / 1000.0).utc.strftime('%M:%S.%L')[0..-3] %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= link_to "View Result", result, class: "text-blue-600 hover:text-blue-900" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          <h3 class="text-lg font-medium text-gray-900 mb-2">No race results found</h3>
          <p class="text-gray-500">This team doesn't have any race results yet.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Tab JavaScript -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const rosterTab = document.getElementById('roster-tab');
      const resultsTab = document.getElementById('results-tab');
      const rosterContent = document.getElementById('roster-content');
      const resultsContent = document.getElementById('results-content');

      function showTab(activeTab, activeContent, inactiveTab, inactiveContent) {
        // Update tab appearance
        activeTab.classList.remove('border-transparent', 'text-gray-500');
        activeTab.classList.add('border-gray-900', 'text-gray-900');
        
        inactiveTab.classList.remove('border-gray-900', 'text-gray-900');
        inactiveTab.classList.add('border-transparent', 'text-gray-500');

        // Show/hide content
        activeContent.classList.remove('hidden');
        inactiveContent.classList.add('hidden');
      }

      // Make sure roster tab is active by default
      rosterContent.classList.remove('hidden');
      resultsContent.classList.add('hidden');

      rosterTab.addEventListener('click', function() {
        showTab(rosterTab, rosterContent, resultsTab, resultsContent);
      });

      resultsTab.addEventListener('click', function() {
        showTab(resultsTab, resultsContent, rosterTab, rosterContent);
      });
    });
  </script>
</div>


