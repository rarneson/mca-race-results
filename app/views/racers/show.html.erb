<% if notice %>
  <div class="alert alert-success mb-6">
    <%= notice %>
  </div>
<% end %>

<div class="container mx-auto max-w-6xl p-6">
  <!-- Back Navigation -->
  <div class="mb-6">
    <%= link_to @back_path, class: "flex items-center text-gray-600 hover:text-gray-800" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <%= @back_text %>
    <% end %>
  </div>

  <!-- Header Section -->
  <div class="bg-gray-100 rounded-lg p-6 mb-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <!-- Profile Avatar -->
        <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center text-white text-2xl font-bold mr-6">
          <%= @racer.first_name.first.upcase if @racer.first_name %>
        </div>
        
        <div>
          <div class="flex items-center mb-2">
            <h1 class="text-3xl font-bold mr-4"><%= @racer.name %></h1>
            <% if @racer.number.present? %>
              <span class="text-2xl text-gray-500">#<%= @racer.number %></span>
            <% end %>
          </div>
          
          <div class="flex items-center gap-4">
            <% if @racer.team %>
              <%= link_to @racer.team_name, team_path(@racer.team), class: "text-gray-600 hover:text-gray-800 hover:underline" %>
            <% else %>
              <span class="text-gray-600"><%= @racer.team_name %></span>
            <% end %>
            <% if @current_category %>
              <span class="<%= category_css_class(@current_category.name) %> px-3 py-1 rounded-full text-sm font-medium">
                <%= @current_category.name %>
              </span>
            <% end %>
          </div>
          
          <div class="flex items-center mt-2 text-orange-500">
            🔥 <%= pluralize(@racer.race_results.where('place <= 5').count, 'podium finish') %>
            <% if @racer.race_results.where('place = 1').any? %>
              ⭐
            <% end %>
          </div>
        </div>
      </div>
      
      <div class="flex gap-2">
        <%= link_to "Edit", edit_racer_path(@racer), class: "btn btn-primary btn-sm" %>
        <%= link_to @back_text, @back_path, class: "btn btn-outline btn-sm" %>
      </div>
    </div>
  </div>

  <!-- Performance Overview Section -->
  <div class="mb-8">
    <h2 class="text-2xl font-bold mb-6">Performance Overview</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <!-- Total Races -->
      <div class="bg-white rounded-lg border p-4 text-center">
        <div class="text-gray-500 text-sm mb-1">📅</div>
        <div class="text-3xl font-bold mb-1"><%= @racer.race_results.count %></div>
        <div class="text-gray-600 text-sm">Total Races</div>
      </div>
      
      <!-- Podiums -->
      <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 text-center">
        <div class="text-orange-600 text-sm mb-1">🥇</div>
        <div class="text-3xl font-bold text-orange-600 mb-1"><%= @racer.race_results.where('place <= 5').count %></div>
        <div class="text-gray-600 text-sm">Podiums</div>
      </div>
      
      <!-- Average Position -->
      <div class="bg-white rounded-lg border p-4 text-center">
        <div class="text-gray-500 text-sm mb-1">🎯</div>
        <div class="text-3xl font-bold mb-1">
          <%= @racer.race_results.any? ? number_with_precision(@racer.race_results.average(:place) || 0, precision: 1) : '0' %>
        </div>
        <div class="text-gray-600 text-sm">Avg Position</div>
      </div>
    </div>
  </div>

  <!-- Career Statistics Section -->
  <div class="mb-8">
    <h2 class="text-2xl font-bold mb-6">Career Statistics</h2>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Success Rates -->
      <div class="bg-white rounded-lg border p-6">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center mr-3">
            🏆
          </div>
          <h3 class="text-lg font-semibold">Success Rates</h3>
        </div>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Win Rate</span>
            <span class="font-bold text-yellow-600">
              <% win_rate = @racer.race_results.count > 0 ? (@racer.race_results.where(place: 1).count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(win_rate, precision: 1) %>%
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Podium Rate</span>
            <span class="font-bold text-orange-600">
              <% podium_rate = @racer.race_results.count > 0 ? (@racer.race_results.where('place <= 5').count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(podium_rate, precision: 1) %>%
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Finish Rate</span>
            <span class="font-bold text-green-600">
              <% finish_rate = @racer.race_results.count > 0 ? (@racer.race_results.where.not(place: nil).count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(finish_rate, precision: 1) %>%
            </span>
          </div>
        </div>
      </div>
      
      <!-- Time Statistics -->
      <div class="bg-white rounded-lg border p-6">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
            ⏱️
          </div>
          <h3 class="text-lg font-semibold">Time Statistics</h3>
        </div>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Best Time</span>
            <span class="font-bold">
              <% best_time = @racer.race_results.minimum(:total_time_ms) %>
              <% if best_time %>
                <%= Time.at(best_time / 1000.0).utc.strftime('%M:%S') %>
              <% else %>
                --:--
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Average Time</span>
            <span class="font-bold">
              <% avg_time = @racer.race_results.average(:total_time_ms) %>
              <% if avg_time %>
                <%= Time.at(avg_time / 1000.0).utc.strftime('%M:%S') %>
              <% else %>
                --:--
              <% end %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Total Race Time</span>
            <span class="font-bold">
              <% total_time = @racer.race_results.sum(:total_time_ms) || 0 %>
              <%= Time.at(total_time / 1000.0).utc.strftime('%H:%M:%S') %>
            </span>
          </div>
        </div>
      </div>
      
      <!-- Position Stats -->
      <div class="bg-white rounded-lg border p-6">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center mr-3">
            🎯
          </div>
          <h3 class="text-lg font-semibold">Position Stats</h3>
        </div>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Best Position</span>
            <span class="font-bold">
              <%= @racer.race_results.minimum(:place) || 'N/A' %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Average Position</span>
            <span class="font-bold">
              <%= @racer.race_results.any? ? number_with_precision(@racer.race_results.average(:place) || 0, precision: 1) : 'N/A' %>
            </span>
          </div>
          
          <div class="flex justify-between items-center">
            <span class="text-gray-600">DNFs</span>
            <span class="font-bold">
              <%= @racer.race_results.where(place: nil).count %>
            </span>
          </div>
        </div>
      </div>
      
    </div>
  </div>

  <!-- Race History & Lap Analysis Section -->
  <div class="mb-8">
    <h2 class="text-2xl font-bold mb-6">Race History & Lap Analysis</h2>
    <% if @racer.race_results.any? %>
      <div class="space-y-4">
        <% @racer.race_results.includes(:race, :race_result_laps).order('races.race_date DESC').each_with_index do |result, index| %>
          <div class="bg-white rounded-lg border">
            <!-- Race Header -->
            <div class="p-4 border-b">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <h3 class="text-lg font-semibold mr-4">
                    <%= result.race&.name || 'Unknown Race' %>
                    <% if index == 0 %>
                      <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full ml-2">Latest</span>
                    <% end %>
                  </h3>
                </div>
                
                <button 
                  class="text-gray-500 hover:text-gray-700"
                  onclick="toggleLapTimes('race-<%= result.id %>')"
                >
                  <span id="race-<%= result.id %>-toggle">Show Lap Times</span>
                  <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>
              </div>
              
              <div class="flex items-center gap-6 mt-2 text-sm text-gray-600">
                <span>📅 <%= result.race&.race_date&.strftime('%m/%d/%Y') || 'Unknown Date' %></span>
                <span>📍 <%= result.race&.location || 'Unknown Location' %></span>
                <span>📏 <%= "32.5 km" %></span>
                <% if result.category %>
                  <span class="<%= category_css_class(result.category.name) %> px-2 py-1 rounded text-xs font-medium">
                    <%= result.category.name %>
                  </span>
                <% end %>
              </div>
              
              <div class="flex items-center mt-3">
                <span class="text-sm text-gray-600 mr-2">Position:</span>
                <% if result.place == 1 %>
                  <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-sm font-medium">1st</span>
                <% elsif result.place && result.place <= 5 %>
                  <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-sm font-medium"><%= result.place.ordinalize %></span>
                <% elsif result.place %>
                  <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded text-sm font-medium"><%= result.place.ordinalize %></span>
                <% else %>
                  <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-sm font-medium">DNF</span>
                <% end %>
                
                <span class="ml-4 font-mono text-lg">
                  <% if result.total_time_ms %>
                    <%= Time.at(result.total_time_ms / 1000.0).utc.strftime('%M:%S') %>
                  <% else %>
                    --:--
                  <% end %>
                </span>
              </div>
            </div>
            
            <!-- Expandable Lap Times -->
            <div id="race-<%= result.id %>-laps" class="hidden p-4 bg-gray-50">
              <% if result.race_result_laps.any? %>
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
                  <% result.race_result_laps.order(:lap_number).each do |lap| %>
                    <div class="text-center p-2 bg-white rounded border">
                      <div class="text-xs text-gray-500 mb-1">Lap <%= lap.lap_number %></div>
                      <div class="font-mono text-sm">
                        <% if lap.lap_time_ms %>
                          <%= Time.at(lap.lap_time_ms / 1000.0).utc.strftime('%M:%S') %>
                        <% else %>
                          --:--
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-gray-500 text-center">No lap time data available for this race.</p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-lg">
        <p class="text-gray-500 text-lg">No race results found for this racer.</p>
      </div>
    <% end %>
  </div>

</div>

<script>
  function toggleLapTimes(raceId) {
    const lapsDiv = document.getElementById(raceId + '-laps');
    const toggleText = document.getElementById(raceId + '-toggle');
    
    if (lapsDiv.classList.contains('hidden')) {
      lapsDiv.classList.remove('hidden');
      toggleText.textContent = 'Hide Lap Times';
    } else {
      lapsDiv.classList.add('hidden');
      toggleText.textContent = 'Show Lap Times';
    }
  }
</script>
