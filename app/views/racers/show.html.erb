<% if notice %>
  <div class="alert alert-success mb-6">
    <%= notice %>
  </div>
<% end %>

<div class="container mx-auto max-w-6xl p-3 md:p-6">
  <%= render "shared/back_navigation", path: @back_path, text: @back_text %>

  <!-- Header Section -->
  <div class="mb-8">
    <div class="flex flex-wrap items-center gap-2 mb-2">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900"><%= @racer.name %></h1>
      <% if @racer.number.present? %>
        <span class="text-xl md:text-2xl text-gray-500">#<%= @racer.number %></span>
      <% end %>
      <% if @current_category %>
        <span class="<%= category_css_class(@current_category.name) %> px-3 py-1 rounded-full text-sm font-medium">
          <%= @current_category.name %>
        </span>
      <% end %>
    </div>
    <p class="text-gray-600">
      <% if @racer.team %>
        <%= link_to @racer.team_name, team_path(@racer.team), class: "text-gray-600 hover:text-gray-800 hover:underline" %>
      <% else %>
        <%= @racer.team_name %>
      <% end %>
    </p>
  </div>

  <!-- Performance Overview Section -->
  <div class="mb-8">
    <h2 class="text-xl md:text-2xl font-bold mb-4 md:mb-6">Performance Overview</h2>
    <div class="grid grid-cols-3 lg:grid-cols-6 gap-3 md:gap-4">
      <!-- Total Races -->
      <div class="bg-white rounded-lg border p-3 md:p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold mb-1"><%= @racer.race_results.count %></div>
        <div class="text-gray-600 text-xs md:text-sm">Total Races</div>
      </div>

      <!-- Podiums -->
      <div class="bg-orange-50 border border-orange-200 rounded-lg p-3 md:p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold text-orange-600 mb-1"><%= @racer.race_results.where('place <= 5').count %></div>
        <div class="text-gray-600 text-xs md:text-sm">Podiums</div>
      </div>

      <!-- Average Position -->
      <div class="bg-white rounded-lg border p-3 md:p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold mb-1">
          <% with_place = @racer.race_results.where.not(place: nil) %>
          <%= with_place.any? ? number_with_precision(with_place.average(:place) || 0, precision: 1) : '0' %>
        </div>
        <div class="text-gray-600 text-xs md:text-sm">Avg Position</div>
      </div>
    </div>
  </div>

  <!-- Career Statistics Section -->
  <div class="mb-8">
    <h2 class="text-xl md:text-2xl font-bold mb-4 md:mb-6">Career Statistics</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-6">

      <!-- Success Rates -->
      <div class="bg-white rounded-lg border p-4 md:p-6">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center mr-3">
            🏆
          </div>
          <h3 class="text-lg font-semibold">Success Rates</h3>
        </div>

        <div class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Win Rate</span>
            <span class="font-bold text-yellow-600">
              <% win_rate = @racer.race_results.count > 0 ? (@racer.race_results.where(place: 1).count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(win_rate, precision: 1) %>%
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-gray-600">Podium Rate</span>
            <span class="font-bold text-orange-600">
              <% podium_rate = @racer.race_results.count > 0 ? (@racer.race_results.where('place <= 5').count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(podium_rate, precision: 1) %>%
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-gray-600">Finish Rate</span>
            <span class="font-bold text-green-600">
              <% finish_rate = @racer.race_results.count > 0 ? (@racer.race_results.where(status: 'finished').count.to_f / @racer.race_results.count * 100) : 0 %>
              <%= number_with_precision(finish_rate, precision: 1) %>%
            </span>
          </div>
        </div>
      </div>

      <!-- Position Stats -->
      <div class="bg-white rounded-lg border p-4 md:p-6">
        <div class="flex items-center mb-4">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center mr-3">
            🎯
          </div>
          <h3 class="text-lg font-semibold">Position Stats</h3>
        </div>
        
        <div class="space-y-4">
          <% placed_results = @racer.race_results.where.not(place: nil) %>
          <div class="flex justify-between items-center">
            <span class="text-gray-600">Best Position</span>
            <span class="font-bold">
              <%= placed_results.minimum(:place) || 'N/A' %>
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-gray-600">Average Position</span>
            <span class="font-bold">
              <%= placed_results.any? ? number_with_precision(placed_results.average(:place) || 0, precision: 1) : 'N/A' %>
            </span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-gray-600">DNFs</span>
            <span class="font-bold">
              <%= @racer.race_results.where(status: 'DNF').count %>
            </span>
          </div>
        </div>
      </div>
      
    </div>
  </div>

  <!-- Race History & Lap Analysis Section -->
  <div class="mb-8">
    <h2 class="text-xl md:text-2xl font-bold mb-4 md:mb-6">Race History & Lap Analysis</h2>
    <% if @race_results_by_year.any? %>
      <div class="space-y-4 md:space-y-8">
        <% @race_results_by_year.each do |year, results| %>
          <div class="bg-gray-50 rounded-lg p-3 md:p-6">
            <!-- Year Header -->
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-bold text-gray-800"><%= year %> Season</h3>
              <span class="text-sm text-gray-600"><%= pluralize(results.count, 'race') %></span>
            </div>
            
            <!-- Races for this year -->
            <div class="space-y-4">
              <% results.each_with_index do |result, index| %>
                <% is_latest_overall = year == @race_results_by_year.keys.first && index == 0 %>
                <div class="bg-white rounded-lg border overflow-hidden">
                  <!-- Race Header -->
                  <div class="p-4">
                    <div class="flex items-center justify-between">
                      <h4 class="text-base md:text-lg font-semibold mr-4">
                        <% if result.race %>
                          <%= link_to result.race.name, race_path(result.race, category: result.category&.name), class: "text-blue-600 hover:text-blue-800 hover:underline" %>
                        <% else %>
                          Unknown Race
                        <% end %>
                        <% if is_latest_overall %>
                          <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full ml-2">Latest</span>
                        <% end %>
                      </h4>
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-2 md:gap-6 mt-2 text-sm text-gray-600">
                      <span>📅 <%= result.race&.race_date&.strftime('%m/%d/%Y') || 'Unknown Date' %></span>
                      <span>📍 <%= result.race&.location || 'Unknown Location' %></span>
                      <% if result.category %>
                        <span class="<%= category_css_class(result.category.name) %> px-2 py-1 rounded text-xs font-medium">
                          <%= result.category.name %>
                        </span>
                      <% end %>
                    </div>
                    
                    <div class="flex items-center mt-3">
                      <span class="text-sm text-gray-600 mr-2">Position:</span>
                      <% if result.status == 'DNF' %>
                        <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-sm font-medium">DNF</span>
                      <% elsif result.place == 1 %>
                        <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-sm font-medium">1st</span>
                      <% elsif result.place && result.place <= 5 %>
                        <span class="bg-orange-100 text-orange-800 px-2 py-1 rounded text-sm font-medium"><%= result.place.ordinalize %></span>
                      <% elsif result.place %>
                        <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded text-sm font-medium"><%= result.place.ordinalize %></span>
                      <% else %>
                        <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-sm font-medium">DNF</span>
                      <% end %>
                      
                      <span class="ml-4 font-mono text-lg">
                        <% if result.total_time_ms %>
                          <%= Time.at(result.total_time_ms / 1000.0).utc.strftime('%M:%S') %>
                        <% else %>
                          --:--
                        <% end %>
                      </span>
                    </div>

                    <button
                      class="text-sm text-gray-500 hover:text-gray-700 mt-3 md:hidden"
                      onclick="toggleLapTimes('race-<%= result.id %>')"
                    >
                      <span id="race-<%= result.id %>-toggle">Show Lap Times</span>
                      <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </button>
                  </div>

                  <!-- Expandable Lap Times -->
                  <div id="race-<%= result.id %>-laps" class="hidden md:block p-4 bg-gray-50">
                    <% if result.race_result_laps.any? %>
                      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
                        <% result.race_result_laps.order(:lap_number).each do |lap| %>
                          <div class="text-center p-2 bg-white rounded border">
                            <div class="text-xs text-gray-500 mb-1">Lap <%= lap.lap_number %></div>
                            <div class="font-mono text-sm">
                              <% if lap.lap_time_ms %>
                                <%= Time.at(lap.lap_time_ms / 1000.0).utc.strftime('%M:%S') %>
                              <% else %>
                                --:--
                              <% end %>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <p class="text-gray-500 text-center">No lap time data available for this race.</p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-lg">
        <p class="text-gray-500 text-lg">No race results found for this racer.</p>
      </div>
    <% end %>
  </div>

</div>

<script>
  function toggleLapTimes(raceId) {
    const lapsDiv = document.getElementById(raceId + '-laps');
    const toggleText = document.getElementById(raceId + '-toggle');
    
    if (lapsDiv.classList.contains('hidden')) {
      lapsDiv.classList.remove('hidden');
      toggleText.textContent = 'Hide Lap Times';
    } else {
      lapsDiv.classList.add('hidden');
      toggleText.textContent = 'Show Lap Times';
    }
  }
</script>
