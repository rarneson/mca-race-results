<% content_for :title, @racer.name %>

<div class="max-w-[1100px] mx-auto px-6">
  <%= render "shared/hud/breadcrumb", trail: [
        { label: "racers", path: racers_path },
        { label: "#{@racer.first_name}_#{@racer.last_name}".parameterize.underscore }
      ] %>

  <%# Header %>
  <section class="pt-2 pb-5">
    <div class="hud-label">
RACER<% if @racer.number.present? %> #<%= @racer.number %><% end %>
    </div>
    <h1 class="hud-mono text-[30px] font-bold text-hud-accent mt-2 mb-1.5 tracking-[0.02em] leading-tight m-0">
      <%= @racer.name.upcase %>
    </h1>
    <% if @current_category || @racer.team_name.present? %>
      <div class="hud-mono text-[12px] text-hud-ink-dim">
        <% if @current_category %>
          <span class="text-hud-amber uppercase tracking-[0.04em]"><%= @current_category.name %></span>
          <% if @racer.team_name.present? %> · <% end %>
        <% end %>
        <% if @racer.team %>
          <%= link_to @racer.team_name, team_path(@racer.team), class: "hud-link" %>
        <% elsif @racer.team_name.present? %>
          <%= @racer.team_name %>
        <% end %>
      </div>
    <% end %>
  </section>

  <%
    all_results = @racer.race_results
    total_count = all_results.count
    finished_results = all_results.where(status: "finished")
    placed = all_results.where.not(place: nil)
    wins = all_results.where(place: 1).count
    podiums = all_results.where("place <= 3").count
    top5 = all_results.where("place <= 5").count
    dnfs = all_results.where(status: "DNF").count
    best_position = placed.minimum(:place)
    avg_position = placed.any? ? placed.average(:place).to_f.round(1) : nil
    win_rate = total_count > 0 ? (wins.to_f / total_count * 100) : 0
    podium_rate = total_count > 0 ? (podiums.to_f / total_count * 100) : 0
    finish_rate = total_count > 0 ? (finished_results.count.to_f / total_count * 100) : 0

    rate_color = ->(pct) {
      if pct >= 50 then "text-hud-accent"
      elsif pct >= 25 then "text-hud-amber"
      else "text-hud-red"
      end
    }
    rate_bar = ->(pct) {
      if pct >= 50 then "bg-hud-accent"
      elsif pct >= 25 then "bg-hud-amber"
      else "bg-hud-red"
      end
    }
  %>

  <%# Performance overview %>
  <div class="mb-3">
    <h2 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
PERFORMANCE_OVERVIEW
    </h2>
  </div>
  <div class="hud-panel p-4 grid gap-3 mb-7" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">
    <%= render "shared/hud/hero_stat",
          label: "▣ RACES",
          value: total_count,
          sub: "total starts",
          accent_color: "text-hud-accent" %>
    <%= render "shared/hud/hero_stat",
          label: "◉ PODIUMS",
          value: podiums,
          sub: "top-3 finishes",
          accent_color: "text-hud-amber" %>
    <%= render "shared/hud/hero_stat",
          label: "⌖ AVG_POS",
          value: avg_position || "—",
          sub: "average finish",
          accent_color: "text-hud-accent" %>
  </div>

  <%# Career statistics %>
  <div class="mb-3">
    <h2 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
CAREER_STATISTICS
    </h2>
  </div>
  <div class="grid gap-4 mb-7" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
    <%# Success rates %>
    <div class="hud-panel p-4">
      <div class="hud-microlabel mb-3.5">★ SUCCESS_RATES</div>
      <% [
        ["WIN_RATE", win_rate],
        ["PODIUM_RATE", podium_rate],
        ["FINISH_RATE", finish_rate]
      ].each_with_index do |(label, pct), idx| %>
        <div class="<%= 'mt-3 pt-3 border-t border-hud-border' if idx > 0 %>">
          <div class="flex justify-between items-center mb-1.5">
            <span class="hud-microlabel"><%= label %></span>
            <span class="hud-mono text-sm font-semibold <%= rate_color.call(pct) %>">
              <%= number_with_precision(pct, precision: 1) %>%
            </span>
          </div>
          <div class="h-1.5 w-full bg-hud-row rounded-sm overflow-hidden">
            <div class="h-full <%= rate_bar.call(pct) %>" style="width: <%= [pct, 100].min %>%"></div>
          </div>
        </div>
      <% end %>
    </div>

    <%# Position stats %>
    <div class="hud-panel p-4">
      <div class="hud-microlabel mb-3.5">◎ POSITION_STATS</div>
      <% [
        ["BEST_POSITION", best_position ? "P#{best_position}" : "—", "text-hud-amber"],
        ["AVG_POSITION", avg_position || "—", "text-hud-accent"],
        ["TOP_5_FINISHES", top5, "text-hud-accent"],
        ["DNFS", dnfs, dnfs == 0 ? "text-hud-accent" : "text-hud-red"]
      ].each_with_index do |(label, value, color), idx| %>
        <div class="<%= 'mt-2.5 pt-2.5 border-t border-hud-border' if idx > 0 %> flex justify-between items-center">
          <span class="hud-microlabel"><%= label %></span>
          <span class="hud-mono text-sm font-semibold <%= color %>"><%= value %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Race history %>
  <div class="mb-3">
    <h2 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
RACE_HISTORY
    </h2>
  </div>

  <% if @race_results_by_year.any? %>
    <% latest_year = @race_results_by_year.keys.first %>
    <% latest_result = @race_results_by_year[latest_year]&.first %>
    <% @race_results_by_year.each do |year, results| %>
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2.5">
          <h3 class="hud-mono text-sm font-bold tracking-[0.04em] text-hud-ink m-0">
            <span class="text-hud-amber">◆</span> <%= year %> SEASON
          </h3>
          <span class="hud-microlabel"><%= pluralize(results.count, "race") %></span>
        </div>

        <div class="grid gap-3">
          <% results.each do |result| %>
            <% is_latest = result == latest_result %>
            <% lap_times = result.race_result_laps.order(:lap_number).map(&:lap_time_ms).compact %>
            <% fastest_lap_ms = lap_times.min %>
            <div class="hud-panel p-6">
              <%# Top row: race title + position/time stats %>
              <div class="flex justify-between items-start gap-4 flex-wrap">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <% if result.race %>
                      <%= link_to result.race.name.upcase, race_path(result.race, category: result.category&.name),
                            class: "hud-mono text-sm font-bold text-hud-accent no-underline hover:underline tracking-[0.02em]" %>
                    <% else %>
                      <span class="hud-mono text-sm font-bold text-hud-ink-dim">UNKNOWN_RACE</span>
                    <% end %>
                    <% if is_latest %>
                      <span class="hud-mono text-[9px] tracking-[0.08em] uppercase text-hud-cyan border border-hud-cyan/60 rounded-sm px-1.5 py-0.5">
                        LATEST
                      </span>
                    <% end %>
                  </div>
                  <div class="hud-mono text-[11px] text-hud-ink-dim mt-2">
                    ◷ <%= result.race&.race_date&.strftime("%B %-d, %Y") || "—" %><%
                      if result.race&.location.present? %> · ⌖ <%= result.race.location %><% end %>
                    <% if result.category %> · ◆ <%= result.category.name %><% end %>
                  </div>
                </div>

                <div class="flex gap-6 items-start">
                  <div class="text-right">
                    <div class="hud-microlabel">POSITION</div>
                    <div class="hud-mono text-base font-bold mt-1
                      <%= if result.dnf?
                            'text-hud-red'
                          elsif result.place == 1
                            'text-hud-amber'
                          elsif result.place && result.place <= 3
                            'text-hud-amber'
                          elsif result.place
                            'text-hud-ink'
                          else
                            'text-hud-red'
                          end %>">
                      <% if result.dnf? %>
                        DNF
                      <% elsif result.place %>
                        P<%= result.place %>
                      <% else %>
                        —
                      <% end %>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="hud-microlabel">TIME</div>
                    <div class="hud-mono text-base font-bold mt-1 <%= result.total_time_ms ? 'text-hud-accent' : 'text-hud-ink-dim' %>">
                      <% if result.total_time_ms %>
                        <%= time_from_ms(result.total_time_ms) %>
                      <% elsif result.total_time_raw.present? %>
                        <span class="text-hud-amber"><%= result.total_time_raw %></span>
                      <% else %>
                        —
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>

              <%# Lap chips %>
              <% if result.race_result_laps.any? && !result.dnf? %>
                <div class="border-t border-dashed border-hud-border mt-5 pt-5">
                  <div class="flex flex-wrap gap-3">
                    <% result.race_result_laps.order(:lap_number).each do |lap| %>
                      <% is_fastest = lap.lap_time_ms && lap.lap_time_ms == fastest_lap_ms %>
                      <div class="px-2.5 py-2 rounded-sm border <%= is_fastest ? 'border-hud-amber bg-hud-amber/10' : 'border-hud-border bg-hud-row' %>">
                        <div class="hud-microlabel <%= 'text-hud-amber' if is_fastest %>">
                          <% if is_fastest %>⚡ <% end %>LAP_<%= lap.lap_number %>
                        </div>
                        <div class="hud-mono text-[12px] mt-1 <%= is_fastest ? 'text-hud-amber font-bold' : 'text-hud-ink' %>">
                          <% if lap.lap_time_ms %>
                            <%= time_from_ms(lap.lap_time_ms) %>
                          <% else %>
                            —
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <%# Footer link %>
              <% if result.race %>
                <div class="mt-5 pt-4 border-t border-hud-border">
                  <%= link_to "VIEW_FULL_RESULTS ▸", race_path(result.race, category: result.category&.name),
                        class: "hud-mono text-[10px] text-hud-accent no-underline hover:underline tracking-[0.06em]" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="hud-panel p-8 text-center">
      <p class="hud-mono text-sm text-hud-ink-dim m-0">$ no race results recorded</p>
    </div>
  <% end %>
</div>
