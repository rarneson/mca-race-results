<% if racers.any? %>
  <div class="hud-panel overflow-hidden">
    <% racers.each_with_index do |racer, i| %>
      <%= link_to racer_path(racer),
            class: "hud-row grid gap-3.5 items-center px-3 py-3 no-underline #{'border-t border-hud-border' if i > 0}",
            style: "grid-template-columns: 1fr auto auto;" do %>
        <div>
          <div class="font-semibold text-sm text-hud-ink"><%= racer.name %></div>
          <div class="hud-mono text-[11px] text-hud-ink-dim mt-0.5">
            ⌖ <%= racer.team_name %>
          </div>
        </div>
        <div class="hud-mono text-[11px] text-hud-ink-dim">
          <%= pluralize(racer.race_results.count, "race") %>
        </div>
        <span class="hud-mono text-hud-accent text-sm">▸</span>
      <% end %>
    <% end %>
  </div>

  <% if pagy.pages > 1 %>
    <div class="flex justify-center mt-7">
      <%= pagy_hud_nav(pagy) %>
    </div>
  <% end %>
<% else %>
  <div class="hud-panel p-8 text-center">
    <p class="hud-mono text-sm text-hud-ink-dim m-0">
      <% if defined?(search_query) && search_query.present? %>
        $ no racers match "<%= search_query %>"
      <% elsif defined?(selected_year) %>
        $ no racers competed in <%= selected_year %>
      <% end %>
    </p>
  </div>
<% end %>
