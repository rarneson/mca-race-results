<% content_for :title, "Racers" %>

<div class="container mx-auto px-4 py-6">
  <% if notice.present? %>
    <div class="alert alert-success mb-5">
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Racers</h1>
      <p class="text-gray-600"><%= pluralize(@pagy.count, 'racer') %> total</p>
    </div>

    <!-- Team Filter -->
    <% if @team_counts.any? %>
      <div class="flex items-center gap-4">
        <%= form_with url: racers_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
          <%= form.label :team, "Team:", class: "text-sm font-medium text-gray-700" %>
          <%= form.select :team,
              options_for_select([["All Teams", ""]] + @team_counts.keys.map { |team| [team, team] }, @selected_team),
              {},
              {
                class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500",
                onchange: "this.form.submit();"
              } %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @racers.any? %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Racer Name
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Team
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Races
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @racers.each do |racer| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to racer.name, racer_path(racer), class: "text-green-600 hover:text-green-900" %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= racer.team_name %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= racer.race_results.count %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-center mt-8">
      <%= pagy_daisyui_nav(@pagy) %>
    </div>
  <% else %>
    <div class="hero min-h-[400px]">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h3 class="text-2xl font-bold mb-4">No racers found</h3>
          <p class="mb-6">Get started by creating your first racer.</p>
        </div>
      </div>
    </div>
  <% end %>
</div>
