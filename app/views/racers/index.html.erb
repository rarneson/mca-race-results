<% content_for :title, "Racers" %>

<div class="container mx-auto px-4 py-6">
  <% if notice.present? %>
    <div class="alert alert-success mb-5">
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Racers</h1>
      <p class="text-gray-600"><span id="racers_count"><%= pluralize(@pagy.count, 'racer') %></span> total</p>
    </div>

    <div class="flex items-center gap-4">
      <!-- Search -->
      <div class="flex items-center gap-2" data-controller="racer-search" data-racer-search-url-value="<%= racers_path %>">
        <label for="racer_search" class="text-sm font-medium text-gray-700">Name:</label>
        <input
          id="racer_search"
          type="text"
          placeholder="Search racers..."
          class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 w-64"
          data-racer-search-target="input"
          data-action="input->racer-search#search keydown->racer-search#handleKeydown"
          value="<%= @search_query %>"
        />
      </div>

      <!-- Team Filter -->
      <% if @team_counts.any? %>
        <div class="flex items-center gap-2">
          <%= form_with url: racers_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
            <%= form.label :team, "Team:", class: "text-sm font-medium text-gray-700" %>
            <%= form.select :team,
                options_for_select([["All Teams", ""]] + @team_counts.keys.map { |team| [team, team] }, @selected_team),
                {},
                {
                  class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500",
                  onchange: "this.form.submit();"
                } %>
            <%= form.hidden_field :search, value: @search_query if @search_query.present? %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="racers_table">
    <%= render partial: "racers/racers_table", locals: { racers: @racers, pagy: @pagy } %>
  </div>
</div>
