<% content_for :title, "Racers" %>

<div class="container mx-auto px-4 py-6">
  <% if notice.present? %>
    <div class="alert alert-success mb-5">
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex flex-col gap-4 mb-8">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Racers</h1>

    <div class="flex flex-row items-center gap-2 sm:gap-4 min-w-0">
      <!-- Search -->
      <div class="flex items-center gap-2" data-controller="racer-search" data-racer-search-url-value="<%= racers_path %>">
        <input
          id="racer_search"
          type="text"
          placeholder="Search racers..."
          class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 w-40 sm:w-64"
          data-racer-search-target="input"
          data-action="input->racer-search#search keydown->racer-search#handleKeydown"
          value="<%= @search_query %>"
        />
      </div>

      <!-- Year Filter -->
      <div class="flex items-center gap-2">
        <%= form_with url: racers_path, method: :get, local: true, class: "flex items-center gap-2" do |form| %>
          <%= form.select :year,
              options_for_select([["All", "All"]] + @available_years.map { |year| [year, year] }, @selected_year),
              {},
              {
                class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500",
                onchange: "this.form.submit();"
              } %>
          <%= form.hidden_field :search, value: @search_query if @search_query.present? %>
          <%= form.hidden_field :team, value: @selected_team if @selected_team.present? %>
        <% end %>
      </div>

      <!-- Team Filter -->
      <% if @team_counts.any? %>
        <div class="flex items-center gap-2 min-w-0 flex-1 max-w-xs">
          <%= form_with url: racers_path, method: :get, local: true, class: "flex items-center gap-2 min-w-0 w-full" do |form| %>
            <%= form.select :team,
                options_for_select([["All Teams", ""]] + @team_counts.keys.map { |team| [team, team] }, @selected_team),
                {},
                {
                  class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 min-w-0 w-full truncate",
                  onchange: "this.form.submit();"
                } %>
            <%= form.hidden_field :search, value: @search_query if @search_query.present? %>
            <%= form.hidden_field :year, value: @selected_year if @selected_year.present? %>
          <% end %>
        </div>
      <% end %>
    </div>

    <p class="text-gray-600" id="racers_count">
      <%= render partial: "racers/racers_count", locals: { count: @pagy.count, selected_year: @selected_year } %>
    </p>
  </div>

  <div id="racers_table">
    <%= render partial: "racers/racers_table", locals: { racers: @racers, pagy: @pagy } %>
  </div>
</div>
