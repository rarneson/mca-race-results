<% content_for :title, "Race results" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Race results</h1>
    <%= link_to "New race result", new_race_result_path, class: "btn btn-primary" %>
  </div>

  <div id="race_results" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @race_results.any? %>
      <% @race_results.each do |race_result| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render race_result %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", race_result, class: "btn btn-ghost btn-sm" %>
            <%= link_to "Edit", edit_race_result_path(race_result), class: "btn btn-ghost btn-sm" %>
            <%= button_to "Destroy", race_result, method: :delete, class: "btn btn-error btn-sm", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No race results found.</p>
    <% end %>
  </div>
</div>
